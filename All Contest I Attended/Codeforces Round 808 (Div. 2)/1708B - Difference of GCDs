void solve() {
    int n, l, r;
    cin >> n >> l >> r;

    vector<int> a(n + 1);
    bool ok = true;

    for(int i = 1; i <= n; i++) {
        a[i] = ((l - 1) / i + 1) * i;
        ok &= (a[i] <= r);
    }

    if(ok) {
        cout << "YES\n";

        for(int i = 1; i <= n; i++) {
            cout << a[i] << (i == n ? '\n' : ' ');
        }
    }
    else {
        cout << "NO";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
