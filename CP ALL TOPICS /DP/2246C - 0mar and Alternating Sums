ll power(ll base, ll exp) {
    ll res = 1;
    base %= MOD;

    while (exp) {
        if (exp & 1) {
            res = (res * base) % MOD;
        }

        base = (base * base) % MOD;
        exp >>= 1;
    }

    return res;
}

void solve() {
    int n;
    cin >> n;

    vector<ll> a(n);

    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }

    ll cntMinus = 0;
    int idx = 0;

    while (idx < n && a[idx] == -1) {
        cntMinus++;
        idx++;
    }

    ll distinct = 0;
    ll consecutive = 0;
    ll prev = -2;

    for (int i = idx; i < n; i++) {
        if (a[i] != prev) {
            if (distinct > 0 && a[i] == prev + 1) {
                consecutive++;
            }

            distinct++;
            prev = a[i];
        }
    }

    ll remaining = n - cntMinus;
    ll ans;

    if (cntMinus == 0) {
        ans = power(2, remaining - distinct);
    } else {
        ans = power(2, cntMinus - 1);
        ans = (ans * power(2, remaining - distinct)) % MOD;
        ans = (ans * (consecutive + 1)) % MOD;
    }

    cout << ans << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
