vector<vector<char>> grid;

bool ok = true;

void try_set(ll row, ll col, char target) {
    if(grid[row][col] == '?') {
        grid[row][col] = target;
    }
    else if(grid[row][col] != target) {
        ok = false;
    }
}

void solve() {
    ll h, w;
    cin >> h >> w;

    vector<ll> r(h), c(w);

    for(ll i = 0; i < h; i++) cin >> r[i];
    for(ll i = 0; i < w; i++) cin >> c[i];

    grid.assign(h + 1, vector<char>(w + 1, '?'));

    for(ll row = 0; row < h; row++) {
        for(ll col = 0; col < r[row]; col++) {
            try_set(row, col, 'F');
        }

        try_set(row, r[row], 'E');
    }

    for(ll col = 0; col < w; col++) {
        for(ll row = 0; row < c[col]; row++) {
            try_set(row, col, 'F');
        }

        try_set(c[col], col, 'E');
    }

    if(!ok) {
        cout << 0;
        return;
    }

    ll ans = 1;

    for(ll row = 0; row < h; row++) {
        for(ll col = 0; col < w; col++) {
            if(grid[row][col] == '?') {
                ans = (ans * 2) % MOD;
            }
        }
    }

    cout << ans;
}






    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t = 1;

   while(t--){
        solve();
        cout<<endl;}

    return 0;
}
