void solve()
{
    int t = 1;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        int ans = 0;

        for (int i = 1; i <= n; i++)
        {
            ans += (2 * i - 1) * i;
        }

        cout << ans << ' ' << 2 * n << '\n';

        for (int i = n; i >= 1; i--)
        {
            cout << "1 " << i << ' ';
            for (int j = 1; j <= n; j++)
            {
                cout << j << ' ';
            }
            cout << '\n';

            cout << "2 " << i << ' ';
            for (int j = 1; j <= n; j++)
            {
                cout << j << ' ';
            }
            cout << '\n';
        }
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
