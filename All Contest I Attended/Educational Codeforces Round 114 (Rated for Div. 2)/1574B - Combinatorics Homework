void solve() {
    ll a, b, c, m;
    cin >> a >> b >> c >> m;

    vector<ll> v = {a, b, c};
    sort(v.begin(), v.end());

    a = v[0];
    b = v[1];
    c = v[2];

    if(c - (a + b + 1) <= m && m <= a + b + c - 3) {
        cout << "YES";
    }
    else {
        cout << "NO";
    }
}

