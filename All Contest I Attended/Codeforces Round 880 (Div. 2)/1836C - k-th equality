ll pw(ll a, ll e) {
    if (e == 0) return 1;
    return (e == 1 ? a : a * pw(a, e - 1));
}

void ans(ll a, ll b) {
    cout << a << " + " << b << " = " << a + b << endl;
}

void solve() {
    ll a, b, c, k;
    cin >> a >> b >> c >> k;

    bool ok = false;

    for (ll i = pw(10, a - 1); i < pw(10, a); i++) {
        ll l = max(pw(10, b - 1), pw(10, c - 1) - i);
        ll r = min(pw(10, b) - 1, pw(10, c) - 1 - i);

        if (l > r) continue;

        ll h = r - l + 1;

        if (k <= h) {
            ans(i, l + k - 1);
            ok = true;
            break;
        }

        k -= h;
    }

    if (!ok) cout << -1 << endl;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
