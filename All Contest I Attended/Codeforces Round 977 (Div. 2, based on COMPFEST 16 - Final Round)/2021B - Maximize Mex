void solve() {
    int n, k;
    cin >> n >> k;

    vector<ll> a(n);

    for(int i = 0; i < n; i++) {
        cin >> a[i];
    }

    sort(a.begin(), a.end());

    map<int, int> m;

    for(int i = 0; i < n; i++) {
        if(a[i] > n) {
            break;
        }
        m[a[i]]++;
    }

    for(int i = 0; i <= n; i++) {
        if(m[i] == 0) {
            cout << i;
            return;
        }

        m[i]--;
        m[i + k] += m[i];
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
