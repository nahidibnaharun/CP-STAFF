void solve() {
  
        
    ll n;
    cin >> n;

    string s;
    cin >> s;

    if (n == 1) {
        cout << s[0] << s[0];
        return;
    }

    if (s[0] == s[1]) {
        cout << s[0] << s[1];
        return;
    }

    ll p = n - 1;

    for (ll i = 0; i < n - 1; i++) {
        if (s[i] < s[i + 1]) {
            p = i;
            break;
        }
    }

    for (ll i = 0; i <= p; i++) {
        cout << s[i];
    }

    for (ll i = p; i >= 0; i--) {
        cout << s[i];
    }
}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
