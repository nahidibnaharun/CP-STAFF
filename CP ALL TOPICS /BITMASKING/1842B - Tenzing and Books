int a[MAX];

void solve() {
    int n, x;
    cin >> n >> x;

    int s = 0;

    for (int i = 1; i <= 3; i++) {
        for (int j = 1; j <= n; j++) {
            cin >> a[j];
        }

        for (int j = 1; j <= n; j++) {
            if ((x | a[j]) != x) {
                break;
            }

            s |= a[j];
        }
    }

    if (s == x) {
        cout << "YES\n";
    }
    else {
        cout << "NO\n";
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
