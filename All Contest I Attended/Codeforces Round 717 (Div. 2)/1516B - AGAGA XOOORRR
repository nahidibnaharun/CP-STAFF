void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        vector<int> pre(n + 1, 0);

        for (int i = 1; i <= n; i++)
        {
            int a;
            cin >> a;
            pre[i] = pre[i - 1] ^ a;
        }

        bool yes = !pre[n];

        for (int i = 1; i <= n; i++)
        {
            for (int j = i + 1; j < n; j++)
            {
                yes |= (pre[i] == (pre[j] ^ pre[i]) && pre[i] == (pre[n] ^ pre[j]));
            }
        }

        cout << (yes ? "YES" : "NO") << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
