bool can(vector<ll> &pos, ll m) {
    ll k = pos.size();
    ll x = k - m;

    for (ll i = 0; i <= m; i++) {
        ll l = pos[i];
        ll r = pos[i + x - 1];

        if (r - l + 1 - x <= m)
            return true;
    }

    return false;
}

void solve() {
    string s;
    cin >> s;

    vector<ll> pos;

    for (ll i = 0; i < s.size(); i++) {
        if (s[i] == '1')
            pos.push_back(i);
    }

    ll lf = 0, rg = pos.size();

    while (rg - lf > 1) {
        ll mid = (lf + rg) / 2;

        if (can(pos, mid))
            rg = mid;
        else
            lf = mid;
    }

    if (pos.empty() || pos.back() - pos.front() == (ll)pos.size() - 1)
        cout << 0;
    else
        cout << rg;
}

