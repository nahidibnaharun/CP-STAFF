void solve() {
    ll n, m;
    cin >> n >> m;

    ll sum = 0;

    vector<priority_queue<ll>> nm(2);
    vector<bool> hv(2, false);

    for (ll i = 1; i <= n; i++) {
        ll a;
        cin >> a;
        nm[i & 1].push(a);
        sum += a;
    }

    for (ll i = 1; i <= m; i++) {
        ll x;
        cin >> x;

        if ((!nm[x & 1].empty() && nm[x & 1].top() >= 0) || !hv[x & 1]) {
            sum -= nm[x & 1].top();
            nm[x & 1].pop();
            hv[x & 1] = true;
        }
    }

    cout << sum;
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
