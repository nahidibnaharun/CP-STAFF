ll n, t;
ll a[MAX], ps[MAX];
void solve()
{
cin >> n;
for (ll i = 1; i <= n; i++)
{
cin >> a[i];
ps[i] = ps[i - 1] + a[i];
}
if (ps[n] != 0)
{
cout << "No\n";
return;
}
bool ok = true;
for (ll i = 1; i <= n; i++)
if (ps[i] < 0)
ok = false;
bool visited_zero = false;
for (ll i = 1; i <= n; i++)
{
if (ps[i] == 0)
visited_zero = true;
else if (visited_zero)
ok = false;
}
cout << (ok ? "Yes\n" : "No\n");
}
int main()
{
ios_base::sync_with_stdio(false);
cin.tie(nullptr);
cin >> t;
while (t--)
solve();
return 0;
}
