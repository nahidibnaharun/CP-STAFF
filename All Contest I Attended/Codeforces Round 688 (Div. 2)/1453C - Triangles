#include <bits/stdc++.h>
using namespace std;

using ll = long long;
using ull = unsigned long long;
using ld = long double;
using ui = unsigned int;

const int INF = 1e9+5;
const int MOD = 1000000007;
const int MAX = 2000;

char a[MAX + 5][MAX + 5];

void solve() {
    ll n;
    cin >> n;

    for (ll i = 1; i <= n; i++) {
        string s;
        cin >> s;
        for (ll j = 1; j <= n; j++) {
            a[i][j] = s[j - 1];
        }
    }

    vector<ll> ans(10, 0);
    vector<ll> mnr(10, INF), mnc(10, INF);
    vector<ll> mxr(10, 0), mxc(10, 0);

    for (ll i = 1; i <= n; i++) {
        for (ll j = 1; j <= n; j++) {
            ll x = a[i][j] - '0';
            mnr[x] = min(mnr[x], i);
            mxr[x] = max(mxr[x], i);
            mnc[x] = min(mnc[x], j);
            mxc[x] = max(mxc[x], j);
        }
    }

    for (ll i = 1; i <= n; i++) {
        for (ll j = 1; j <= n; j++) {
            ll x = a[i][j] - '0';

            ans[x] = max(ans[x],
                         max(mxr[x] - i, i - mnr[x]) *
                         max(n - j, j - 1));

            ans[x] = max(ans[x],
                         max(mxc[x] - j, j - mnc[x]) *
                         max(n - i, i - 1));
        }
    }

    for (ll i = 0; i < 10; i++) {
        cout << ans[i] << (i == 9 ? '\n' : ' ');
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout << endl;
    }

    return 0;
}
