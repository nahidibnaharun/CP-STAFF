bool bad(vector<int> v)
{
    int s = 0;

    for (int x : v)
        s += x;

    if (s % 2)
        return false;

    bitset<200005> b;
    b[0] = 1;

    for (int x : v)
        b |= (b << x);

    return b[s / 2];
}

void solve()
{
    int n;
    cin >> n;

    vector<int> v(n);
    for (int i = 0; i < n; i++)
        cin >> v[i];

    if (bad(v))
    {
        pair<int, int> mn = {20, 0};

        for (int i = 0; i < n; i++)
        {
            mn = min(mn, {__builtin_ctz(v[i]), i + 1});
        }

        cout << 1 << "\n";
        cout << mn.second;
    }
    else
    {
        cout << 0;
    }
}

