ll calcAnswer(vector<ll> &numbers) {
    sort(numbers.begin(), numbers.end());

    ll result = 0;
    int sz = numbers.size();

    for (int i = 0; i < sz; i++) {
        result += abs(numbers[i] - numbers[sz / 2]);
    }

    return result;
}

void solve() {
    int n, m;
    cin >> n >> m;

    vector<vector<ll>> matrix(n, vector<ll>(m));

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            cin >> matrix[i][j];
        }
    }

    ll answer = 0;

    int left_row = 0, right_row = n - 1;

    while (left_row <= right_row) {
        int left_column = 0, right_column = m - 1;

        while (left_column <= right_column) {
            vector<ll> cur_numbers;

            cur_numbers.push_back(matrix[left_row][left_column]);

            if (left_row != right_row)
                cur_numbers.push_back(matrix[right_row][left_column]);

            if (left_column != right_column)
                cur_numbers.push_back(matrix[left_row][right_column]);

            if (left_row != right_row && left_column != right_column)
                cur_numbers.push_back(matrix[right_row][right_column]);

            answer += calcAnswer(cur_numbers);

            left_column++;
            right_column--;
        }

        left_row++;
        right_row--;
    }

    cout << answer;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
