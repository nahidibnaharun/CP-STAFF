ll n,a[MAX];

void solve() {
    cin >> n;

    map<ll,ll> mp;

    for(ll i=1;i<=n;i++){
        cin >> a[i];
        mp[a[i]] = i;
    }

    for(ll i=n;i>=1;i--){
        ll x = mp[i];

        for(ll j=x;j<=n;j++){
            if(mp[a[j]] == 0) break;

            cout << a[j] << " ";
            mp[a[j]] = 0;
        }
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--){
        solve();
        cout << endl;
    }

    return 0;
}
