void solve() {
    int n, k;
    string s;

    cin >> n >> k >> s;

    if (n == 1 && k != 0) {
        cout << 0;
        return;
    }

    if (k == 0) {
        cout << s;
        return;
    }

    int cnt = 0;

    for (int i = 0; i < n; i++) {
        if (i == 0 && s[i] != '1') {
            s[i] = '1';
            cnt++;
        }
        else if (i != 0 && s[i] != '0') {
            s[i] = '0';
            cnt++;
        }

        if (cnt == k) {
            break;
        }
    }

    cout << s;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
