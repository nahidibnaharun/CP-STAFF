const int N = 109;
int s[N], e[N];

void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        for (int i = 0; i < n; i++)
        {
            cin >> s[i] >> e[i];
        }

        bool ok = true;

        for (int i = 1; i < n; i++)
        {
            if (s[i] >= s[0] && e[i] >= e[0])
            {
                ok = false;
            }
        }

        if (!ok)
        {
            cout << -1 << "\n";
            continue;
        }

        cout << s[0] << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
