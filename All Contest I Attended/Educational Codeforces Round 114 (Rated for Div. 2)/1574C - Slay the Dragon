void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n);

    for(auto &x : a) {
        cin >> x;
    }

    sort(a.begin(), a.end());

    ll sum = accumulate(a.begin(), a.end(), 0LL);

    ll m;
    cin >> m;

    while(m--) {
        ll x, y;
        cin >> x >> y;

        ll i = lower_bound(a.begin(), a.end(), x) - a.begin();

        ll ans = 2e18;

        if(i > 0) {
            ans = min(ans, (x - a[i - 1]) + max(0LL, y - sum + a[i - 1]));
        }

        if(i < n) {
            ans = min(ans, max(0LL, y - sum + a[i]));
        }

        cout << ans << endl;
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while(t--){
        solve();
    }

    return 0;
}
