void solve() {
    ll n;
    cin >> n;

    string s;
    cin >> s;

    vector<int> visited(n + 1, 0);

    for (int i = 0; i < n; i++) {
        if (s[i] == '1') {
            visited[i + 1] = 1;
        }
    }

    ll sum = 0;

    for (int i = 1; i <= n; i++) {
        for (int j = i; j <= n; j += i) {
            if (visited[j] == 0) {
                sum += i;
                visited[j] = 2;
            } 
            else if (visited[j] == 2) {
                continue;
            } 
            else {
                break;
            }
        }
    }

    cout << sum;
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
