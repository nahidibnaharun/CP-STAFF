void solve() {
    ll n;
    cin >> n;

    vector<int> high;
    ll sum = 0;

    for (ll i = 1; i <= n; i++) {
        ll x, y;
        cin >> x >> y;

        sum += 2 * (x + y);
        high.push_back(max(x, y));
    }

    if (n == 1) {
        cout << sum;
        return;
    }

    sort(high.begin(), high.end(), greater<int>());

    ll kom = 0;
    int sz = high.size();

    for (ll i = 0; i < sz; i++) {
        if (i == 0 || i == sz - 1) {
            if (i == 0) {
                kom += high[i + 1];
            }
            if (i == sz - 1) {
                kom += high[i];
            }
        } else {
            kom += high[i];
            kom += high[i + 1];
        }
    }

    cout << sum - kom;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
