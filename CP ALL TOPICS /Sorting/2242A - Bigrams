void solve() {
    int k;
    cin >> k;

    vector<int> a(k);
    int mx = 0, cnt = 0;

    for (int i = 0; i < k; i++) {
        cin >> a[i];
        mx = max(mx, a[i]);
        if (a[i] == 2) cnt++;
    }

    if (mx > 2 || cnt > 1) cout << "YES\n";
    else cout << "NO\n";
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
