void solve() {
    int n;
    cin >> n;

    string s;
    cin >> s;

    int ans = 0;
    int cnt = 0;

    for (char c : s) {
        if (c == '*') {
            cnt = 0;
        } else {
            cnt++;
        }

        ans = max(ans, (cnt + 1) / 2);
    }

    cout << ans << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
