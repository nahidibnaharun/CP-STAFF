const int N = 105;

int n;
int a[N];
ll dp[N][N][N][2];

ll solveDP(int pos, int even, int odd, int par)
{
    if (pos == n - 1)
    {
        if (a[pos] == 0)
        {
            if (par == 0)
            {
                if (even > 0) return 0;
                if (odd > 0) return 1;
            }
            else
            {
                if (even > 0) return 1;
                if (odd > 0) return 0;
            }
        }
        return 0;
    }

    ll &res = dp[pos][even][odd][par];
    if (res != -1) return res;

    res = INF;

    if (a[pos] != 0)
    {
        int cur = a[pos] % 2;
        if (a[pos + 1] == 0)
        {
            res = solveDP(pos + 1, even, odd, cur);
        }
        else
        {
            int nxt = a[pos + 1] % 2;
            res = solveDP(pos + 1, even, odd, cur) + (cur != nxt);
        }
        return res;
    }

    if (par == 0)
    {
        if (a[pos + 1] != 0)
        {
            int nxt = a[pos + 1] % 2;

            if (even > 0)
                res = min(res, solveDP(pos + 1, even - 1, odd, 0) + (0 != nxt));

            if (odd > 0)
                res = min(res, solveDP(pos + 1, even, odd - 1, 1) + (0 != 1) + (1 != nxt));
        }
        else
        {
            if (even > 0)
                res = min(res, solveDP(pos + 1, even - 1, odd, 0));

            if (odd > 0)
                res = min(res, solveDP(pos + 1, even, odd - 1, 1) + 1);
        }
    }
    else
    {
        if (a[pos + 1] != 0)
        {
            int nxt = a[pos + 1] % 2;

            if (even > 0)
                res = min(res, solveDP(pos + 1, even - 1, odd, 0) + (1 != 0) + (0 != nxt));

            if (odd > 0)
                res = min(res, solveDP(pos + 1, even, odd - 1, 1) + (1 != nxt));
        }
        else
        {
            if (even > 0)
                res = min(res, solveDP(pos + 1, even - 1, odd, 0) + 1);

            if (odd > 0)
                res = min(res, solveDP(pos + 1, even, odd - 1, 1));
        }
    }

    return res;
}

void solve()
{
    cin >> n;

    int even = n / 2;
    int odd = (n + 1) / 2;

    for (int i = 0; i < n; i++)
    {
        cin >> a[i];
        if (a[i] != 0)
        {
            if (a[i] % 2) odd--;
            else even--;
        }
    }

    if (n == 1)
    {
        cout << 0 << "\n";
        return;
    }

    memset(dp, -1, sizeof(dp));

    ll ans = INF;

    if (a[0] == 0)
    {
        if (even > 0)
            ans = min(ans, solveDP(1, even - 1, odd, 0));

        if (odd > 0)
            ans = min(ans, solveDP(1, even, odd - 1, 1));
    }
    else
    {
        int cur = a[0] % 2;
        ans = solveDP(1, even, odd, cur);
    }

    cout << ans << "\n";
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
