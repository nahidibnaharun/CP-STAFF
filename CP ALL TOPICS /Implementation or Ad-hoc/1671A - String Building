void solve() {
    string s;
    cin >> s;

    bool ans = true;
    int n = s.size();

    for (int i = 0; i < n; i++) {
        if ((i == 0 || s[i] != s[i - 1]) &&
            (i == n - 1 || s[i] != s[i + 1])) {
            ans = false;
        }
    }

    cout << (ans ? "YES\n" : "NO\n");
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
