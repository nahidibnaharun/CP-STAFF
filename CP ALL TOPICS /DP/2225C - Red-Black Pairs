void solve() {
    ll n;
    cin >> n;

    vector<string> d(2);
    cin >> d[0] >> d[1];

    vector<ll> dp(n + 1, INF);
    dp[0] = 0;

    for (ll i = 0; i < n; i++) {
        dp[i + 1] = min(dp[i + 1], dp[i] + (d[0][i] != d[1][i]));

        if (i + 1 < n) {
            dp[i + 2] = min(dp[i + 2],
                            dp[i] + (d[0][i] != d[0][i + 1]) +
                            (d[1][i] != d[1][i + 1]));
        }
    }

    cout << dp[n];
}





    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin>>t;

   while(t--){
        solve();
        cout<<endl;}

    return 0;
}
