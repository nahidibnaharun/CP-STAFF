int ask(int i, int j){
    cout << "? " << i << " " << j << endl;
    cout.flush();
    int x; cin >> x;
    if(x == -1) exit(0);
    return x;
}

void solve(){
    int n; cin >> n;

    for(int i = 2; i <= n; i++){
        int l = 2*i - 1, r = 2*i;
        if(ask(l, r)){
            cout << "! " << l << endl;
            cout.flush();
            return;
        }
    }

    if(ask(1, 3)){
        cout << "! 1" << endl;
        cout.flush();
        return;
    }

    if(ask(1, 4)){
        cout << "! 1" << endl;
        cout.flush();
        return;
    }

    cout << "! 2" << endl;
    cout.flush();
}


int main(){
    ios_base::sync_with_stdio(false);
	cin.tie(NULL);
    
    ll tt; cin >> tt;
    while(tt--){
        solve();
        cout << endl;
    }
    
    
    return 0;   
}
