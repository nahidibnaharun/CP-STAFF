void solve()
{
    ll n;
    cin >> n;

    vector<ll> cnt(3, 0);

    for (ll i = 0; i < n; i++)
    {
        ll x;
        cin >> x;
        cnt[x % 3]++;
    }

    ll res = cnt[0];

    ll mn = min(cnt[1], cnt[2]);
    res += mn;

    cnt[1] -= mn;
    cnt[2] -= mn;

    res += (cnt[1] + cnt[2]) / 3;

    cout << res << "\n";
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
    }

    return 0;
}
