ll n;
ll a[MAX];

void solve() {
    cin >> n;

    for (ll i = 1; i <= n; i++) {
        cin >> a[i];
    }

    cout << n - 1 << '\n';

    if (n > 1) {
        cout << 1 << ' ' << n << '\n';
    }

    ll x = ((a[1] + a[n]) % 2) ? a[1] : a[n];

    for (ll i = 2; i < n; i++) {
        if ((x + a[i]) % 2) {
            cout << 1 << ' ' << i << '\n';
        }
        else {
            cout << i << ' ' << n << '\n';
        }
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
