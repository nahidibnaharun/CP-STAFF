void solve() {
    ll n, m;
    cin >> n >> m;

    for(ll i = 0; i < n; i++) {
        for(ll j = 0; j < m; j++) {
            if(i % 2 == 0) {
                cout << (n / 2 + i / 2) * m + j + 1 << " ";
            } else {
                cout << (i / 2) * m + j + 1 << " ";
            }
        }
        cout << endl;
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
    }

    return 0;
}
