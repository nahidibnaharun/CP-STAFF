void solve() {
       ll n, m;
    cin >> n >> m;

    ll c = 0, cnt = 0, mx = 1;

    for (ll i = 0; i < n; i++) {
        ll a;
        cin >> a;

        if (i == 0) {
            c = a;
            cnt = 1;
        }
        else if (a != c) {
            c = a;
            mx = max(mx, cnt);
            cnt = 1;
        }
        else {
            cnt++;
        }
    }

    mx = max(mx, cnt);

    if (mx < m) cout << "YES";
    else cout << "NO";
}





    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin>>t;

   while(t--){
        solve();
        cout<<endl;}

    return 0;
}
