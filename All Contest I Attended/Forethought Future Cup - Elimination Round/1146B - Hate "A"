void solve() {
    string s;
    cin >> s;

    int l = s.size();

    string s1 = "", s2 = "", s3 = "";
    string raj = "";

    int j = l - 1;

    for (int i = 0; i < l; i++) {
        if (s[i] != 'a') {
            s1 += s[i];
            s2 = s[j] + s2;
            j--;
        }

        s3 += s[i];

        if (s1 == s2 && j == i) {
            cout << s3;
            return;
        }

        if (s[i] != 'a')
            raj += s[i];
    }

    if (raj.empty()) {
        cout << s;
        return;
    }

    cout << ":(";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;
    // cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
