void solve() {
     ll n;
    cin >> n;

    vector<ll> v(n);
    for (ll i = 0; i < n; i++) cin >> v[i];

    vector<ll> ans;
    ans.push_back(0);

    for (ll i = 0; i < n; i++) {
        ll x = v[i];
        if (x != 0 && ans.back() - x >= 0) {
            cout << -1 ;
            return;
        } else {
            ans.push_back(ans.back() + x);
        }
    }

    for (ll i = 1; i < ans.size(); i++) {
        cout << ans[i] << " ";
    }
}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
