void solve() {
    int n;
    ll x;
    cin >> n >> x;

    vector<ll> a(n);
    ll sum = 0;

    for (int i = 0; i < n; i++) {
        cin >> a[i];
        sum += a[i];
    }

    sort(a.begin(), a.end());

    ll ans = 0;
    ll prev = -1;

    for (int i = n - 1; i >= 0; i--) {
        ll cur = (x - sum >= 0 ? (x - sum) / (i + 1) : -1);
        ans += 1LL * (i + 1) * (cur - prev);
        prev = cur;
        sum -= a[i];
    }

    cout << ans << '\n';
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
