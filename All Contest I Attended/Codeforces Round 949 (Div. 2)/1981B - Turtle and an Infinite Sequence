void solve() {
    ll n, m;
    cin >> n >> m;

    ll ans = 0;

    for (int i = 0; i <= 30; ++i) {
        ll x = n & ((1LL << (i + 1)) - 1);
        ll t = (1LL << i) - x;

        if (n >= (1LL << i)) {
            t = min(t, x + 1);
        }

        if (x >= (1LL << i) || t <= m) {
            ans |= (1LL << i);
        }
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while(t--){
        solve();
        cout << '\n';
    }

    return 0;
}
