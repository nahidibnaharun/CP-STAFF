void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        ll a;
        cin >> a;

        // number of 1-bits in a
        int pop = __builtin_popcountll(a);

        // number of solutions = 2^popcount
        ll ans = 1LL << pop;

        cout << ans << "\n";
    }
}

