void solve()
{
    int n;
    cin >> n;
    vector<int> v(n + 1);
    for (int i = 1; i <= n; i++)
        cin >> v[i];
    int val = 1, cnt = 0;
    for (int i = 1; i <= n; i++)
    {
        val = max(val, v[i]);
        if (i == val)
            cnt++;
    }
    cout << cnt << nl;
}

