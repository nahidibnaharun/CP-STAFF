void solve()
{
    int t = 1;
    cin >> t;

    while (t--)
    {
        int l, r, x;
        cin >> l >> r >> x;
        int a, b;
        cin >> a >> b;

        int ans = -1;

        if (a == b)
            ans = 0;
        else if (abs(a - b) >= x)
            ans = 1;
        else if (r - max(a, b) >= x || min(a, b) - l >= x)
            ans = 2;
        else if ((r - b >= x && a - l >= x) || (r - a >= x && b - l >= x))
            ans = 3;

        cout << ans << '\n';
    }
}

