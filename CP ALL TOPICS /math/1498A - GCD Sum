ll gcd_sum(ll num)
{
    ll tmp = num, digitsum = 0;

    while (tmp > 0)
    {
        digitsum += tmp % 10;
        tmp /= 10;
    }

    ll g = __gcd(num, digitsum);
    return g;
}

void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        ll n;
        cin >> n;

        if (gcd_sum(n) != 1)
            cout << n << "\n";
        else if (gcd_sum(n + 1) != 1)
            cout << n + 1 << "\n";
        else if (gcd_sum(n + 2) != 1)
            cout << n + 2 << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
