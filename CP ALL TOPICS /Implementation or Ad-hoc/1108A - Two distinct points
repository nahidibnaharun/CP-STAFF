void solve() {
    int l1, r1, l2, r2;
    cin >> l1 >> r1 >> l2 >> r2;

    vector<int> a = {l1, r1, l2, r2};

    int ans1 = 0, ans2 = 0;

    for (auto it : a) {
        for (auto jt : a) {
            if (l1 <= it && it <= r1 &&
                l2 <= jt && jt <= r2 &&
                it != jt) {

                ans1 = it;
                ans2 = jt;
            }
        }
    }

    cout << ans1 << " " << ans2;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
