bool prime(int x)
{
    if (x < 2)
        return false;
    for (int i = 2; i * i <= x; i++)
    {
        if (x % i == 0)
            return false;
    }
    return true;
}
void solve()
{
    int n;
    cin >> n;
    int x = n + 1;
    while (!prime(x))
    {
        x++;
    }
    int a = x;
    x += n;
    while (!prime(x))
    {
        x++;
    }
    cout << x * a;
}
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll Test_Case;
    cin >> Test_Case;
    while (Test_Case--)
    {
        solve();
        cout << endl;
    }

    return 0;
}
