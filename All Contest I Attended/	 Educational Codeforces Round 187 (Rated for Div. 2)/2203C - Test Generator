bool get(ll x, ll a, ll lim)
{

    ll f = 0;

    for (int i = 59; i >= 0; i--)
    {
        f <<= 1;

        if (((x >> i) & 1LL) == 1)
        {
            f++;
        }

        if (((a >> i) & 1LL) == 1)
        {
            f -= min(lim, f);
        }
    }

    return (f == 0);

}

void solve()
{

    ll x, a;
    cin >> x >> a;

    if (!get(x, a, (1LL << 60)))
    {
        cout << -1;
        return;
    }

    ll l = 0, r = (1LL << 60);

    while (l <= r)
    {
        ll m = l + (r - l) / 2;

        if (get(x, a, m))
        {
            r = m - 1;
        }
        else
        {
            l = m + 1;
        }
    }

    cout << l;

}
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t ;
    cin >> t;
    while (t--)
    {
        solve();
        cout << endl;
    }
    return 0;
}
