void solve() {
    ll n;
    cin >> n;

    string s;
    cin >> s;

    ll cnt = 0;
    ll c = 0;
    ll cn = 0;

    for (char x : s) {
        if (x == '0') {
            cnt++;
        }

        if (x == '1') {
            c++;
        }

        if (x >= '0' && x <= '5') {
            cn++;
        }
    }

    ll l = 0;
    ll r = n / 4;
    ll val = 0;

    while (l <= r) {
        ll mid = l + (r - l) / 2;

        ll mn = max(0LL, mid - cnt);
        ll mx = min({mid, c / 2, cn - 2 * mid});

        if (mn <= mx) {
            val = mid;
            l = mid + 1;
        } else {
            r = mid - 1;
        }
    }

    cout << val << '\n';
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
