void solve() {
  
  

 int n;
    cin >> n;

    vector<int> a(n + 1);

    for (int i = 1; i <= n; i++)
        cin >> a[i];

    bool hd = false, he = false;

    for (int i = 1; i <= n; i++) {
        if (a[i] % 2)
            hd = true;
        else
            he = true;
    }

    if (he && hd) {
        cout << -1;
        return;
    }

    vector<int> op;

    for (int i = 29; i >= 0; i--)
        op.push_back(1 << i);

    if (he)
        op.push_back(1);

    cout << op.size() << '\n';

    for (int x : op)
        cout << x << ' ';
}



    
