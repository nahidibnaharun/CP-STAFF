void solve() {
    ll t;
    cin >> t;
    while (t--) {
        ll n, bag, k, dif;
        cin >> n >> bag >> k;
        vector<ll> a(n);
        for (ll i = 0; i < n; i++) {
            cin >> a[i];
        }

        if (n == 1) {
            cout << "YES\n";
            continue;
        }

        bool ok = true;
        for (ll i = 0; i < n - 1; i++) {
            if (a[i+1] - a[i] <= k) {
                dif = k - (a[i+1] - a[i]);
                bag += min(a[i], dif);
            } else {
                if (a[i+1] - a[i] - bag > k) {
                    ok = false;
                    break;
                } else {
                    bag -= (a[i+1] - a[i] - k);
                }
            }
        }

        cout << (ok ? "YES" : "NO") << '\n';
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);

    solve();
    return 0;
}
