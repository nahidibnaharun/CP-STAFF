#include <bits/stdc++.h>
using namespace std;

using ll = long long;
using ull = unsigned long long;
using ld = long double;
using ui = unsigned int;

const int INF = 1e9 + 5;
const int MOD = 1000000007;
const int MAX = 200005;

void solve() {
    int n;
    cin >> n;

    vector<vector<int>> graph(n + 1);
    vector<int> indegree(n + 1, 0);
    set<int> q;

    for (int i = 1; i <= n; i++) {
        int k;
        cin >> k;

        while (k--) {
            int a;
            cin >> a;
            graph[a].push_back(i);
            indegree[i]++;
        }
    }

    for (int i = 1; i <= n; i++) {
        if (indegree[i] == 0) {
            q.insert(i);
        }
    }

    vector<int> order;

    while (!q.empty()) {
        int curr;

        if (!order.empty()) {
            auto it = q.lower_bound(order.back());
            if (it != q.end()) {
                curr = *it;
                q.erase(it);
            } else {
                curr = *q.begin();
                q.erase(q.begin());
            }
        } else {
            curr = *q.begin();
            q.erase(q.begin());
        }

        order.push_back(curr);

        for (int next : graph[curr]) {
            indegree[next]--;
            if (indegree[next] == 0) {
                q.insert(next);
            }
        }
    }

    if ((int)order.size() != n) {
        cout << -1 << '\n';
        return;
    }

    int res = 1;
    for (int i = 1; i < n; i++) {
        if (order[i - 1] > order[i]) {
            res++;
        }
    }

    cout << res << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
