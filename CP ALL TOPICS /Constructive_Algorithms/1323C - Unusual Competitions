void solve() {
    int n;
    cin >> n;

    string s;
    cin >> s;

    if (n % 2) {
        cout << -1 << "\n";
        return;
    }

    int open = 0, close = 0;
    int x = 0, ans = 0;

    for (int i = 0; i < n; i++) {
        if (s[i] == '(') {
            open++;
            x++;
        } else {
            close++;

            if (x > 0) {
                x--;
            } else {
                ans += 2;
                x--;
            }
        }
    }

    ans += x * 2;

    if (open != close) {
        cout << -1 << "\n";
    } else {
        cout << ans << "\n";
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
