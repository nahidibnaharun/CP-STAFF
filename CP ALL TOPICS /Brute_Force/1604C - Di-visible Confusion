void solve() {
    ll n;
    cin >> n;

    bool ok = true;

    for(ll i = 1; i <= n; i++) {
        ll x;
        cin >> x;

        bool found = false;

        for(ll j = i + 1; j >= 2; j--) {
            if(x % j) {
                found = true;
                break;
            }
        }

        ok &= found;
    }

    if(ok) {
        cout << "YES";
    }
    else {
        cout << "NO";
    }
}






int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
