int cnt[MAX];

void reset(vector<ll> &a) {
    for(ll i = 0; i < a.size(); i++) {
        cnt[a[i]] = 0;
    }
}

void solve() {
    ll n;
    cin >> n;

    vector<ll> a(2 * n);

    for(ll i = 0; i < 2 * n; i++) {
        cin >> a[i];
    }

    sort(a.begin(), a.end());

    ll t = 0;

    for(ll i = 0; i < 2 * n - 1; i++) {

        for(ll j = 0; j < 2 * n; j++)
            cnt[a[j]]++;

        ll j = 2 * n - 1;
        ll x = a[i] + a[j];

        vector<ll> rm;

        for(ll op = 0; op < n; op++) {

            while(j > 0 && cnt[a[j]] == 0)
                j--;

            rm.push_back(a[j]);
            rm.push_back(x - a[j]);

            cnt[a[j]]--;
            cnt[x - a[j]]--;

            if(cnt[a[j]] < 0 || cnt[x - a[j]] < 0) {
                cnt[a[j]] = 0;
                cnt[x - a[j]] = 0;
                break;
            }

            x = max(x - a[j], a[j]);

            if(op + 1 == n)
                t = 1;
        }

        reset(a);

        if(t) {
            cout << "YES" << endl;
            cout << rm[0] + rm[1] << endl;

            for(ll i = 0; i < rm.size(); i++) {
                cout << rm[i] << " \n"[i % 2];
            }

            return;
        }
    }

    cout << "NO";
}






    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
