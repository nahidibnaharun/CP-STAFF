void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n);

    for (ll i = 0; i < n; i++) {
        cin >> a[i];
    }

    ll ans = n + 5;

    vector<ll> last(n + 1, -1);

    for (ll i = 0; i < n; i++) {

        if (last[a[i]] != -1) {
            ans = min(ans, i - last[a[i]] + 1);
        }

        last[a[i]] = i;
    }

    if (ans > n) ans = -1;

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--){
        solve();
        cout << endl;
    }

    return 0;
}
