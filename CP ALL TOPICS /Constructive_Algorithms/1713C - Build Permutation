void recurse(ll r) {
    if (r < 0) return;
    
    ll s = sqrt(2 * r);
    s *= s;
    ll l = s - r;
    
    recurse(l - 1);
    
    for (; l <= r; l++, r--) {
        ans[l] = r;
        ans[r] = l;
    }
}

void solve() {
    ll n;
    cin >> n;
    
    recurse(n - 1);
    
    for (ll i = 0; i < n; i++) {
        cout << ans[i] << ' ';
    }
    cout << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
