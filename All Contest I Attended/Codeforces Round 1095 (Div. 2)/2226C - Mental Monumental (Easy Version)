void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n);
    for (ll i = 0; i < n; i++) cin >> a[i];

    multiset<ll> ms(a.begin(), a.end());

    ll l = 0, r = n + 1;

    while (l < r) {
        ll md = (l + r) / 2;

        assert((ll)ms.size() == n);

        bool ok = true;
        vector<ll> removed;

        for (ll i = md - 1; i >= 0; i--) {
            if (ms.count(i)) {
                removed.push_back(i);
                ms.erase(ms.find(i));
            } else {
                ll x = *ms.rbegin();
                if (x < 2 * i + 1) {
                    ok = false;
                    break;
                }
                removed.push_back(x);
                ms.erase(ms.find(x));
            }
        }

        for (auto &z : removed) ms.insert(z);

        if (ok) l = md + 1;
        else r = md;
    }

    assert(l > 0);
    --l;

    cout << l;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
