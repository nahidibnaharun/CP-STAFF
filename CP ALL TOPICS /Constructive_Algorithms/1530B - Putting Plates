void solve() {
    ll a, b;
    cin >> a >> b;

    for(ll j = 0; j < a; j++) {
        for(ll k = 0; k < b; k++) {

            if(a == 2) {
                if(j == 0) {
                    if(k % 2 == 0) cout << 1;
                    else cout << 0;
                }
                else cout << 0;
            }
            else {
                if(a % 2 == 0) {
                    if(j == 0) {
                        if(k % 2 == 0) cout << 1;
                        else cout << 0;
                    }
                    else if(j == a - 1) {
                        if(k % 2 == 0) cout << 1;
                        else cout << 0;
                    }
                    else if(j > a - 4) cout << 0;
                    else {
                        if(j % 2 == 0) {
                            if(b < 3) {
                                if(k == 0) cout << 1;
                                else cout << 0;
                            }
                            else {
                                if(k == 0 || k == b - 1) cout << 1;
                                else cout << 0;
                            }
                        }
                        else cout << 0;
                    }
                }
                else {
                    if(j == 0) {
                        if(k % 2 == 0) cout << 1;
                        else cout << 0;
                    }
                    else if(j == a - 1) {
                        if(k % 2 == 0) cout << 1;
                        else cout << 0;
                    }
                    else {
                        if(j % 2 == 0) {
                            if(b < 3) {
                                if(k == 0) cout << 1;
                                else cout << 0;
                            }
                            else {
                                if(k == 0 || k == b - 1) cout << 1;
                                else cout << 0;
                            }
                        }
                        else cout << 0;
                    }
                }
            }
        }
        cout << endl;
    }
    cout << endl;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
    }

    return 0;
}
