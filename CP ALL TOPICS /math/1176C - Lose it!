void solve()
{
    ll n;
    cin >> n;

    vector<ll> p = {4, 8, 15, 16, 23, 42};

    vector<ll> a(n);
    for (ll i = 0; i < n; i++)
    {
        cin >> a[i];
        a[i] = lower_bound(p.begin(), p.end(), a[i]) - p.begin();
    }

    vector<ll> seq(6, 0);

    for (ll i = 0; i < n; i++)
    {
        if (a[i] == 0)
        {
            seq[0]++;
        }
        else
        {
            if (seq[a[i] - 1] > 0)
            {
                seq[a[i] - 1]--;
                seq[a[i]]++;
            }
        }
    }

    cout << n - seq[5] * 6 << "\n";
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
