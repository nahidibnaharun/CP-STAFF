void solve() {
    int n;
    cin >> n;

    vector<int> cnt(200000 + 1);

    for (int i = 0; i < n; i++) {
        int x;
        cin >> x;

        cnt[x]++;

        if (cnt[x] > 2) {
            cout << "NO";
            return;
        }
    }

    cout << "YES\n";

    cout << count(cnt.begin(), cnt.end(), 2) << '\n';

    for (int i = 0; i <= 200000; i++) {
        if (cnt[i] == 2) {
            cout << i << ' ';
            cnt[i]--;
        }
    }

    cout << '\n';

    cout << count(cnt.begin(), cnt.end(), 1) << '\n';

    for (int i = 200000; i >= 0; i--) {
        if (cnt[i] == 1) {
            cout << i << ' ';
            cnt[i]--;
        }
    }

    cout << '\n';
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
