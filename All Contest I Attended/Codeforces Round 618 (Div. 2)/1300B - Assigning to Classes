#include<bits/stdc++.h>
using namespace std;
#define lli long long int
#define flash_all ios_base::sync_with_stdio(0);cin.tie(0);cout.tie(0);

const int sz = 200005;
lli a[sz];

int main()
{
    flash_all;

    int T,t;
    cin>>T;

    while(T--)
    {
        lli n,i,x,y,ans=1e10;

        cin>>n;

        for(i=1; i<=2*n; i++)
            cin>>a[i];

        sort(a+1,a+2*n+1);

        for(i=1; i<=2*n; i+=2)
        {
            x=(i+1)/2;
            y=(2*n-i+1)/2;

            ans=min(ans,abs(a[x]-a[x+y]));
        }

        cout<<ans<<"\n";
    }

    return 0;
}
