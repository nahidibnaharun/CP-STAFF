void solve() {
    ll n, m;
    cin >> n >> m;

    vector<ll> a(n), b(n);

    for (ll i = 0; i < n; i++) {
        cin >> a[i];
    }

    for (ll i = 0; i < n; i++) {
        cin >> b[i];
    }

    ll ans = INF;

    sort(b.begin(), b.end());

    for (ll i = 0; i < n; i++) {
        ll delta = b[0] - a[i];

        if (delta < 0) {
            delta += m;
        }

        vector<ll> c;

        for (ll j = 0; j < n; j++) {
            c.push_back((a[j] + delta) % m);
        }

        sort(c.begin(), c.end());

        bool ok = true;

        for (ll j = 0; j < n; j++) {
            if (c[j] != b[j]) {
                ok = false;
                break;
            }
        }

        if (ok) {
            ans = min(ans, delta);
        }
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
