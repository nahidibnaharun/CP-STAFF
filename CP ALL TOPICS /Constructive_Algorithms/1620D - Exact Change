int n;
vector<int> a;

bool ok(int val, int c1, int c2, int c3) {
    for (int i = 0; i <= c1; i++) {
        for (int j = 0; j <= c2; j++) {
            if (i + 2 * j > val) continue;
            if ((val - i - 2 * j) % 3) continue;
            if ((val - i - 2 * j) / 3 <= c3) return true;
        }
    }
    return false;
}

bool chk(int c1, int c2, int c3) {
    for (auto x : a) {
        if (!ok(x, c1, c2, c3)) return false;
    }
    return true;
}

void solve() {
    cin >> n;
    a.resize(n);

    for (int i = 0; i < n; i++) cin >> a[i];

    int mx = *max_element(a.begin(), a.end());
    int ans = INF;

    for (int c1 = 0; c1 < 3; c1++) {
        for (int c2 = 0; c2 < 3; c2++) {
            int c3 = max(0, (mx - c1 - 2 * c2 + 2) / 3);

            if (chk(c1, c2, c3)) {
                ans = min(ans, c1 + c2 + c3);
            }
        }
    }

    cout << ans << endl;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
    }

