bool is_distinct(ll x) {
    string s = to_string(x);
    set<char> st(s.begin(), s.end());

    return st.size() == s.size();
}

void solve() {
    ll l, r;
    cin >> l >> r;

    for(ll i = l; i <= r; i++) {
        if(is_distinct(i)) {
            cout << i;
            return;
        }
    }

    cout << -1;
}






    
