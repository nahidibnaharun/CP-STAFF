int cnt[MAX];

void solve()
{
    int t = 1;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        int ans = 0;

        for (int i = 1; i <= n; i++)
        {
            cnt[i] = 0;
        }

        int a;

        for (int i = 1; i <= n; i++)
        {
            cin >> a;
            cnt[a]++;

            if (cnt[a] == 2)
            {
                ans++;
            }
        }

        cout << ans << '\n';
    }
}

