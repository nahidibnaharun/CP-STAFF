const int OPEN = 1;
const int CLOSE = -1;
const int DR = 1000000;

struct Event {
    int x, type, id;

    bool operator<(const Event &other) const {
        if (x != other.x) {
            return x < other.x;
        }
        return type == OPEN && other.type == CLOSE;
    }
};

int n, s;
int x[MAX], v[MAX], dir[MAX], dist[MAX];
int cnt[2];
vector<Event> events;

bool can(ld t) {
    events.clear();
    cnt[0] = cnt[1] = 0;

    for (int i = 0; i < n; i++) {
        if (dist[i] <= (ll)v[i] * t) {
            cnt[dir[i]]++;
        } else if (dist[i] <= (ll)(v[i] + s) * t) {
            ld A = (ld)1 / (s - v[i]) - (ld)v[i] / (s - v[i]) / (s + v[i]);
            ld B = (ld)dist[i] / (s + v[i]) - t;
            ld r = -B / A;

            if (dir[i] == 0) {
                events.push_back({x[i], OPEN, dir[i]});
                events.push_back({lround(min((ld)DR + 1, floor(x[i] + r))), CLOSE, dir[i]});
            } else {
                events.push_back({lround(max((ld)-1.0, ceil(x[i] - r))), OPEN, dir[i]});
                events.push_back({x[i], CLOSE, dir[i]});
            }
        }
    }

    if (cnt[0] > 0 && cnt[1] > 0) {
        return true;
    }

    sort(events.begin(), events.end());

    for (auto e : events) {
        cnt[e.id] += e.type;

        if (cnt[0] > 0 && cnt[1] > 0) {
            return true;
        }
    }

    return false;
}

void solve() {
    cin >> n >> s;

    for (int i = 0; i < n; i++) {
        cin >> x[i] >> v[i] >> dir[i];

        dir[i]--;

        if (dir[i] == 0) {
            dist[i] = x[i];
        } else {
            dist[i] = DR - x[i];
        }
    }

    ld left = 0;
    ld right = 1e6;

    for (int i = 0; i < 50; i++) {
        ld mid = (left + right) / 2;

        if (can(mid)) {
            right = mid;
        } else {
            left = mid;
        }
    }

    cout << fixed << setprecision(20) << (left + right) / 2 << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
