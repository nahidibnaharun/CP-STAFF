void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n);
    ll ans = 0, sum = 0;

    for (ll i = 0; i < n; i++) {
        cin >> a[i];

        if (a[i] == 0) {
            ans++;
            a[i]++;
        }

        sum += a[i];
    }

    if (sum == 0) ans++;

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
