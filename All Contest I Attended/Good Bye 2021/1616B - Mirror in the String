void solve() {
  
   ll n;
    cin >> n;

    string s;
    cin >> s;

    ll k = 1;

    for (ll i = 1; i < n; i++) {
        if (s[i] < s[i-1]) {
            k++;
        }
        else if (s[i] == s[i-1]) {
            if (i == 1) k++;
            else break;
        }
        else break;
    }

    string t = "";

    for (ll i = 0; i < k; i++) {
        t += s[i];
    }

    for (ll i = k-1; i >= 0; i--) {
        t += s[i];
    }

    cout << t;
}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
