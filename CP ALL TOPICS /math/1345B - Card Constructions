void solve()
{
 ll n;
    cin >> n;

    ll c = 0;

    while (n > 2)
    {
        ll t = 5;
        ll now = 2;

        while (n >= t + now)
        {
            now = t + now;
            t += 3;
        }

        n -= now;
        c++;
    }

    if (n >= 2)
    {
        c++;
    }

    cout << c;

}
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t ;
    cin >> t;
    while (t--)
    {
        solve();
        cout << endl;
    }
    return 0;
}
