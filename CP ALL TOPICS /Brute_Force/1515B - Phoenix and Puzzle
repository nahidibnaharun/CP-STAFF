bool isSquare(int x) {
    int y = sqrt(x);
    return y * y == x;
}

void solve() {
    int n;
    cin >> n;

    if (n % 2 == 0 && isSquare(n / 2)) {
        cout << "YES\n";
    }
    else if (n % 4 == 0 && isSquare(n / 4)) {
        cout << "YES\n";
    }
    else {
        cout << "NO\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
