void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n, c;
        cin >> n >> c;

        vector<int> a(n);
        map<int, int> mp;

        int ans = 0;

        for (int i = 0; i < n; i++)
        {
            cin >> a[i];
            mp[a[i]]++;

            if (mp[a[i]] <= c)
            {
                ans++;
            }
        }

        cout << ans << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
