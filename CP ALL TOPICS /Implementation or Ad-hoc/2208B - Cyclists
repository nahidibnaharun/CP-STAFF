int n, k, p;
ll m;
int a[MAX];

void solve()
{
    int t = 1;
    cin >> t;

    while (t--)
    {
        cin >> n >> k >> p >> m;

        for (int i = 1; i <= n; i++)
        {
            cin >> a[i];
        }

        multiset<int> opt;

        for (int i = 1; i <= k - 1; i++)
        {
            opt.insert(a[i]);
        }

        for (int i = k; i <= p - 1; i++)
        {
            opt.insert(a[i]);
            m -= *opt.begin();
            opt.erase(opt.begin());
        }

        m -= a[p];

        if (m < 0)
        {
            cout << 0 << "\n";
            continue;
        }

        ll sum = a[p];
        opt.clear();

        for (int i = 1; i <= n; i++)
        {
            if (i != p)
            {
                opt.insert(a[i]);
            }
        }

        for (int i = 1; i <= n - k; i++)
        {
            sum += *opt.begin();
            opt.erase(opt.begin());
        }

        cout << 1 + m / sum << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
