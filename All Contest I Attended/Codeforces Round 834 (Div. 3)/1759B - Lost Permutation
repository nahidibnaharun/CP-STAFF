#include <bits/stdc++.h>
using namespace std;

using ll = long long;

void solve() {
    int t;
    cin >> t;
    while (t--) {
        int m;
        ll s;
        cin >> m >> s;
        vector<int> b(m);
        ll sum_b = 0;
        for (int i = 0; i < m; i++) {
            cin >> b[i];
            sum_b += b[i];
        }

        ll total = sum_b + s;
        ll n = (sqrt(1 + 8*total) - 1) / 2; 
        if (n*(n+1)/2 != total) {
            cout << "NO\n";
            continue;
        }

        int mx = *max_element(b.begin(), b.end());
        if (mx > n) {
            cout << "NO\n";
        } else {
            cout << "YES\n";
        }
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    solve();
    return 0;
}
