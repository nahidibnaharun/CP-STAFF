void solve() {
    string s;
    cin >> s;

    ll n = s.size();
    ll ans = n;

    for (ll x = 0; x < 26; x++) {
        char c = char('a' + x);

        ll i = 0;
        ll cur = 0;

        while (i < n) {
            ll j = i;

            while (j < n && ((s[j] == c) == (s[i] == c))) {
                j++;
            }

            if (s[i] != c) {
                cur = max(cur, j - i);
            }

            i = j;
        }

        if (cur == 0) {
            ans = 0;
            break;
        }

        ll pw = 0;

        while ((1LL << pw) <= cur) {
            pw++;
        }

        ans = min(ans, pw);
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
