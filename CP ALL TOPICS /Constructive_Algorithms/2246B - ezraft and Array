void solve() {
    ll n;
    cin >> n;

    if (n == 1) {
        cout << 1 << "\n";
    }
    else if (n == 2) {
        cout << -1 << "\n";
    }
    else if (n == 3) {
        cout << "1 2 3\n";
    }
    else {
        vector<ll> a = {1, 2, 3};

        while (a.size() < n) {
            a.push_back(a.back() * 2);
        }

        for (ll x : a) {
            cout << x << " ";
        }
        cout << "\n";
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
