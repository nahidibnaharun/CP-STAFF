int a[MAX];

void solve() {
    int n;
    cin >> n;

    for (int i = 1; i <= n; i++) {
        cin >> a[i];
    }

    set<int> st;
    st.insert(a[1]);

    bool ok = true;

    for (int i = 2; i <= n; i++) {
        int prev = a[i - 1];

        if (prev != a[i]) {
            if (prev < a[i]) {
                auto it = st.upper_bound(prev);

                if (it != st.end() && *it < a[i]) {
                    ok = false;
                    break;
                }
            }

            if (prev > a[i]) {
                auto it = st.lower_bound(prev);

                if (it != st.begin()) {
                    --it;

                    if (*it > a[i]) {
                        ok = false;
                        break;
                    }
                }
            }
        }

        st.insert(a[i]);
    }

    cout << (ok ? "YES" : "NO") << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int tc;
    cin >> tc;

    while (tc--) {
        solve();
    }

    return 0;
}
