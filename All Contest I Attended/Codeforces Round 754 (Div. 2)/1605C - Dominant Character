void solve() {
    ll n;
    string s;

    cin >> n >> s;

    ll ans = INF;

    for(ll i = 0; i < n; i++) {
        vector<ll> f(3, 0);

        f[s[i] - 'a']++;

        for(ll j = i + 1; j < min(n, i + 7LL); j++) {
            f[s[j] - 'a']++;

            if(f[0] > f[1] && f[0] > f[2]) {
                ans = min(ans, j - i + 1);
            }
        }
    }

    if(ans == INF) ans = -1;

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
