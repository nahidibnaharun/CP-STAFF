void solve()
{
   
    string s;
    cin >> s;

    int sum = 0;
    vector<int> a;

    for (int i = 0; i < (int)s.size(); ++i)
    {
        int x = s[i] - '0';
        sum += x;
        a.push_back(x - (i == 0));
    }

    sort(a.begin(), a.end());

    int ans = 0;

    while (sum > 9)
    {
        sum -= a.back();
        a.pop_back();
        ++ans;
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t ;
    cin >> t;
    while (t--)
    {
        solve();
        cout << endl;
    }
    return 0;
}
