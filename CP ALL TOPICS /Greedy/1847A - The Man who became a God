void solve() {
    ll n, k;
    cin >> n >> k;

    ll arr[n];

    for(ll i = 0; i < n; i++) {
        cin >> arr[i];
    }

    vector<ll> v;
    ll sum = 0;

    for(ll i = 1; i < n; i++) {
        v.push_back(abs(arr[i] - arr[i - 1]));
        sum += v.back();
    }

    sort(v.begin(), v.end());

    for(ll groups = 1; groups < k; groups++) {
        sum -= v.back();
        v.pop_back();
    }

    cout << sum;
}






int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
