void solve() {
    ll n, m;
    cin >> n >> m;

    vector<ll> a(n + 1);

    ll total = 0, reqd = 0, ans = 0;

    for (ll i = 1; i <= n; i++) {
        cin >> a[i];
        total += a[i];
    }

    sort(a.begin() + 1, a.end());

    ll prev = 0;

    for (ll i = 1; i <= n; i++) {
        reqd++;

        if (a[i] > prev)
            prev++;
    }

    reqd += (a[n] - prev);

    ans = total - reqd;

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
