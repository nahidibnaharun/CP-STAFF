void solve() {
    int n;
    cin >> n;

    string s, t;
    cin >> s >> t;

    string r1 = "", r2 = "";

    bool bj = true;

    for (int i = 0; i < n; i++) {
        if (s[i] == t[i]) {
            r1 += s[i];
            r2 += t[i];
        }
        else {
            if (bj) {
                r1 += '(';
                r2 += ')';
            }
            else {
                r1 += ')';
                r2 += '(';
            }

            bj ^= 1;
        }
    }

    int t1 = 0, t2 = 0;

    bj = true;

    for (int i = 0; i < n; i++) {
        if (r1[i] == '(') {
            ++t1;
        }
        else {
            --t1;
        }

        if (r2[i] == '(') {
            ++t2;
        }
        else {
            --t2;
        }

        if (t1 < 0 || t2 < 0) {
            bj = false;
        }
    }

    if (t1 != 0 || t2 != 0) {
        bj = false;
    }

    if (bj) {
        cout << "YES";
    }
    else {
        cout << "NO";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
