void solve() {
    int n;
    cin >> n;

    vector<int> a(n), b(n);

    for (int &x : a) {
        cin >> x;
    }

    for (int &x : b) {
        cin >> x;
    }

    ll sum = 0;

    for (int i = 0; i < n; i++) {
        sum += max(a[i], b[i]);
    }

    ll ans = 0;

    for (int i = 0; i < n; i++) {
        ans = max(ans, sum + min(a[i], b[i]));
    }

    cout << ans;
}






int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
