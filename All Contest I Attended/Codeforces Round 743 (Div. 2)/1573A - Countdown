#include <bits/stdc++.h>
using namespace std;

using ll = long long;
using ull = unsigned long long;
using ld = long double;
using ui = unsigned int;

const int INF = 1e9 + 5;
const int MOD = 1000000007;
const int MAX = 200005;

void solve() {
    ll n;
    cin >> n;

    string s;
    cin >> s;

    ll ans = 0;

    for (ll i = 0; i < n; i++) {
        ans += (s[i] - '0');
        if (i < n - 1 && s[i] > '0') {
            ans++;
        }
    }

    cout << ans << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
