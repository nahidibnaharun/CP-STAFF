void solve()
{
    int t = 1;
    cin >> t;

    while (t--)
    {
        ll n, m;
        cin >> n >> m;

        vector<ll> arr(n + 2), pre(n + 2);

        for (int i = 1; i <= n; i++)
        {
            cin >> arr[i];
            pre[i] = arr[i];
        }

        for (int i = 1; i <= m; i++)
            pre[i] += pre[i - 1];

        ll s = pre[m];
        ll ans = 0;

        priority_queue<ll> vl;

        for (int i = m; i >= 1; i--)
        {
            if (pre[i] < s)
            {
                s -= (2LL * vl.top());
                vl.pop();
                ans++;
            }
            vl.push(arr[i]);
        }

        ll temp = s;

        priority_queue<ll, vector<ll>, greater<ll>> vll;

        for (int i = m + 1; i <= n; i++)
        {
            temp += arr[i];
            vll.push(arr[i]);

            if (temp < s)
            {
                temp += (-2LL * vll.top());
                vll.pop();
                ans++;
            }
        }

        cout << ans << '\n';
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
