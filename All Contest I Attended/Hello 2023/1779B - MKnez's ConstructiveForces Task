void solve()
{
    int t = 1;
    cin >> t;

    while (t--)
    {
        ll n;
        cin >> n;

        if (n == 3)
        {
            cout << "NO\n";
        }
        else
        {
            cout << "YES\n";

            if (n % 2)
            {
                for (int i = 0; i < n; i++)
                {
                    if (i % 2)
                        cout << -1 * (n / 2) << ' ';
                    else
                        cout << (n / 2) - 1 << ' ';
                }
                cout << '\n';
            }
            else
            {
                ll m = n / 2;
                while (m--)
                    cout << "1 -1 ";
                cout << '\n';
            }
        }
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
