int N, M, X;
int H[100001];

void solve() {
    cin >> N >> M >> X;

    cout << "YES\n";

    set<pair<int, int>> s;

    for (int i = 1; i <= M; i++) {
        s.insert({0, i});
    }

    for (int i = 0; i < N; i++) {
        cin >> H[i];

        pair<int, int> p = *s.begin();
        s.erase(p);

        cout << p.second << " ";

        s.insert({p.first + H[i], p.second});
    }

    cout << "\n";
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
