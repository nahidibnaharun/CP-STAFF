void solve() {
    ll n, m;
    cin >> n >> m;
    ll q;
    cin >> q;

    ll g = gcd(n, m);
    ll ng = n / g;
    ll mg = m / g;

    while (q--) {
        ll sx, sy, ex, ey;
        cin >> sx >> sy >> ex >> ey;
        sy--; ey--;

        ll v1 = (sx == 1) ? sy / ng : sy / mg;
        ll v2 = (ex == 1) ? ey / ng : ey / mg;

        if (v1 == v2) {
            cout << "YES\n";
        } else {
            cout << "NO\n";
        }
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);

    solve();
    return 0;
}
