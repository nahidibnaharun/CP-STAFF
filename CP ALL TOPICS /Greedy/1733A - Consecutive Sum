ll n, k;
ll a[MAX];

void solve() {
    cin >> n >> k;

    for (ll i = 1; i <= n; i++) {
        ll x;
        cin >> x;
        a[i % k] = max(a[i % k], x);
    }

    ll s = 0;
    for (ll i = 0; i < k; i++) {
        s += a[i];
    }

    cout << s;

    fill(a, a + k, 0);
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
