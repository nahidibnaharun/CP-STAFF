void solve() {
    int n;
    string s;

    cin >> n >> s;

    vector<int> p(3);
    iota(p.begin(), p.end(), 0);

    string colors = "RGB";
    string res = "";

    int ans = INF;

    do {
        string t;
        int cnt = 0;

        for (int i = 0; i < n; ++i) {
            t += colors[p[i % 3]];
            cnt += (t[i] != s[i]);
        }

        if (ans > cnt) {
            ans = cnt;
            res = t;
        }

    } while (next_permutation(p.begin(), p.end()));

    cout << ans << endl;
    cout << res;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
