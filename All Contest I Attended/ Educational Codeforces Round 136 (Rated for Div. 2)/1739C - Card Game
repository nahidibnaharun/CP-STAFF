ll dp[65][65][3];

void solve() {
    ll n;
    cin >> n;

    memset(dp, 0, sizeof dp);

    ll k = n / 2;
    dp[0][0][2] = 1;

    for (ll i = 0; i <= k; i++) {
        for (ll j = 0; j <= k; j++) {
            for (ll t = 0; t < 3; t++) {
                ll turn = (i + j) % 4;

                if (turn == 0 || turn == 3) {
                    if (i < k)
                        dp[i + 1][j][t == 2 ? 0 : t] = (dp[i + 1][j][t == 2 ? 0 : t] + dp[i][j][t]) % MOD;
                    if (j < k)
                        dp[i][j + 1][t] = (dp[i][j + 1][t] + dp[i][j][t]) % MOD;
                } else {
                    if (i < k)
                        dp[i + 1][j][t] = (dp[i + 1][j][t] + dp[i][j][t]) % MOD;
                    if (j < k)
                        dp[i][j + 1][t == 2 ? 1 : t] = (dp[i][j + 1][t == 2 ? 1 : t] + dp[i][j][t]) % MOD;
                }
            }
        }
    }

    for (ll i = 0; i < 3; i++) {
        cout << dp[k][k][i] % MOD << " ";
    }
    cout << '\n';
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
    }

    return 0;
}
