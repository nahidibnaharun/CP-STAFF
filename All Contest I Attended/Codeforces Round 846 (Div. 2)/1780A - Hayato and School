void solve() {
    int n;
    cin >> n;

    vector<int> odd, even;

    for (int i = 1; i <= n; i++) {
        int x;
        cin >> x;

        if (x % 2 == 0) {
            even.push_back(i);
        } else {
            odd.push_back(i);
        }
    }

    if (odd.size() >= 3) {
        cout << "YES\n";
        cout << odd[0] << " " << odd[1] << " " << odd[2];
    } 
    else if (odd.size() >= 1 && even.size() >= 2) {
        cout << "YES\n";
        cout << odd[0] << " " << even[0] << " " << even[1];
    } 
    else {
        cout << "NO";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
