const int N = 2e5 + 5;

ll n;
ll a[N], b[N];

void solve(){
    cin >> n;

    map<ll,ll> m;

    for(int i = 1; i <= n; i++){
        cin >> a[i];
        m[a[i]]++;
    }

    for(int i = 1; i <= n; i++){
        cin >> b[i];
    }

    ll ans = 0;

    for(int i = 1; i <= n; i++){
        if(i == 1){
            ll g = __gcd(a[i], a[i+1]);
            if(g != a[i]) ans++;
        }
        else if(i == n){
            ll g = __gcd(a[i], a[i-1]);
            if(g != a[i]) ans++;
        }
        else{
            ll g1 = __gcd(a[i], a[i-1]);
            ll g2 = __gcd(a[i], a[i+1]);

            ll lcm = (g1 * g2) / __gcd(g1, g2);

            if(lcm < a[i]) ans++;
        }
    }

    cout << ans;
}
int main(){
    ios_base::sync_with_stdio(false);
	cin.tie(NULL);
    
    ll tt; cin >> tt;
    while(tt--){
        solve();
        cout << endl;
    }
    
    
    return 0;   
}
