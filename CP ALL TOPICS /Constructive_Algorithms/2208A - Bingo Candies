int n;
int cnt[MAX];

void solve()
{
    int t = 1;
    cin >> t;

    while (t--)
    {
        cin >> n;

        int tmp;
        bool flag = true;

        for (int i = 1; i <= n * n; i++)
        {
            cin >> tmp;
            cnt[tmp]++;

            if (cnt[tmp] > n * (n - 1))
            {
                flag = false;
            }
        }

        if (flag)
        {
            cout << "YES\n";
        }
        else
        {
            cout << "NO\n";
        }

        for (int i = 1; i <= n * n; i++)
        {
            cnt[i] = 0;
        }
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
