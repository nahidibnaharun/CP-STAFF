void solve() {
    int n, x;
    cin >> n >> x;

    vector<int> w(n);
    int sum = 0;

    for (int i = 0; i < n; i++) {
        cin >> w[i];
        sum += w[i];
    }

    if (sum == x) {
        cout << "NO\n";
        return;
    }

    cout << "YES\n";

    for (int i = 0; i < n; i++) {
        if (x == w[i]) {
            swap(w[i], w[i + 1]);
        }

        cout << w[i] << " ";
        x -= w[i];
    }

    cout << "\n";
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
