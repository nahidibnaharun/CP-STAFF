ll check(vector<ll> a) {

    for(ll i = 0; i + 1 < a.size(); i++) {

        if(a[i] > a[i + 1]) {
            return 0;
        }

        a[i + 1] -= a[i];
        a[i] = 0;
    }

    if(a.back() == 0)
        return 1;

    return 0;
}

void solve() {

    ll n;
    cin >> n;

    vector<ll> a(n);

    for(ll i = 0; i < n; i++) {
        cin >> a[i];
    }

    if(check(a)) {
        cout << "YES";
        return;
    }

    if(n == 1) {
        cout << "NO";
        return;
    }

    swap(a[0], a[1]);

    if(check(a)) {
        cout << "YES";
        return;
    }

    swap(a[0], a[1]);
    swap(a[n - 2], a[n - 1]);

    if(check(a)) {
        cout << "YES";
        return;
    }

    swap(a[n - 2], a[n - 1]);

    vector<ll> p(n), s(n);
    vector<ll> b = a;

    p[0] = b[0];

    for(ll i = 1; i < n; i++) {

        if(p[i - 1] == -1 || b[i - 1] > b[i]) {
            p[i] = -1;
        }
        else {
            b[i] -= b[i - 1];
            b[i - 1] = 0;
            p[i] = b[i];
        }
    }

    b = a;

    s[n - 1] = b[n - 1];

    for(ll i = n - 2; i >= 0; i--) {

        if(s[i + 1] == -1 || b[i + 1] > b[i]) {
            s[i] = -1;
        }
        else {
            b[i] -= b[i + 1];
            b[i + 1] = 0;
            s[i] = b[i];
        }
    }

    for(ll i = 1; i + 2 < n; i++) {

        vector<ll> c = {p[i - 1], a[i], a[i + 1], s[i + 2]};

        if(p[i - 1] == -1 || s[i + 2] == -1) {
            continue;
        }

        swap(c[1], c[2]);

        if(check(c)) {
            cout << "YES";
            return;
        }
    }

    cout << "NO";
}






    
