}
for (ll i = 0; i < n - 1; i++)
{
for (ll j = 0; j < m - 1; j++)
{
ll sum = a[i][j] + a[i][j + 1] + a[i + 1][j] + a[i + 1][j + 1];
if (sum == 3)
{
cout << "NO\n";
return;
}
}
}
cout << "YES\n";
}
