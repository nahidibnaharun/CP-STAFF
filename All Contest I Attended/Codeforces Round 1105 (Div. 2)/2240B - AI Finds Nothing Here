ll power(ll x, ll y) {
    ll res = 1;

    while (y) {
        if (y & 1)
            res = (res * x) % MOD;

        x = (x * x) % MOD;
        y >>= 1;
    }

    return res;
}

void solve() {
    ll n, m, r, c;
    cin >> n >> m >> r >> c;

    ll exponent = (n * (c - 1) + m * (r - 1) - (c - 1) * (r - 1)) % (MOD - 1);

    cout << power(2, exponent);
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
