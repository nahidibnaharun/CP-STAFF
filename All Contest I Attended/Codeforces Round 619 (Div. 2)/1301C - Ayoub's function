void solve() {
    int n, m;
    cin >> n >> m;

    ll ans = 1LL * n * (n + 1) / 2;

    int z = n - m;
    int k = z / (m + 1);

    ans -= 1LL * (m + 1) * k * (k + 1) / 2;
    ans -= 1LL * (z % (m + 1)) * (k + 1);

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
