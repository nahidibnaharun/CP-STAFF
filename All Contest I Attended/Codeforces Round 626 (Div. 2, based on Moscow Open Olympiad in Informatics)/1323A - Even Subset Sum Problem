void solve() {
    int n;
    cin >> n;

    vector<int> a(n);
    vector<int> even, odd;

    for (int i = 0; i < n; i++) {
        cin >> a[i];

        if (a[i] % 2 == 0) {
            even.push_back(i + 1);
        } else {
            odd.push_back(i + 1);
        }
    }

    if (!even.empty()) {
        cout << 1 << "\n";
        cout << even[0] << "\n";
    } else if (odd.size() >= 2) {
        cout << 2 << "\n";
        cout << odd[0] << " " << odd[1] << "\n";
    } else {
        cout << -1 << "\n";
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
