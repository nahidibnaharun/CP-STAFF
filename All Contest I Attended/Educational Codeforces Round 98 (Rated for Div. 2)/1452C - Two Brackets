ll calc(string s, char x, char y) {
    ll bal = 0;
    ll cnt = 0;

    for(char c : s) {
        if(c == y) {
            if(bal > 0) {
                bal--;
                cnt++;
            }
        }
        else if(c == x) {
            bal++;
        }
    }

    return cnt;
}

void solve() {
    string s;
    cin >> s;

    cout << calc(s, '(', ')') + calc(s, '[', ']');
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
