void solve() {
    ll n, c;
    cin >> n >> c;

    vector<ll> a(n);
    for (ll i = 0; i < n; i++) {
        cin >> a[i];
    }

    sort(a.begin(), a.end());

    for (ll i = 0; i < n; i++) {
        a[i] -= c;
    }

    for (ll i = 0; i < n / 2; i++) {
        a[i] = max(a[i], 0LL);
    }

    ll ans = 0;
    for (ll x : a) {
        ans += x;
    }

    cout << ans << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int tc;
    cin >> tc;

    while (tc--) {
        solve();
    }

    return 0;
}
