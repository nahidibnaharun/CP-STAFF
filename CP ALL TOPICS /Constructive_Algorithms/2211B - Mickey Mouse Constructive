void solve(){
    ll x, y, val, cnt = 0;
    cin >> x >> y;

    val = abs(x - y);

    vector<int> v(x, 1), p(y, -1);

    for(int i = 1; i <= val; i++){
        if(val % i == 0) cnt++;
    }

    if(val == 0) cnt = 1;

    cout << cnt << "\n";

    for(auto &x : v) cout << x << " ";
    for(auto &x : p) cout << x << " ";
    cout << "\n";
}

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while(t--){
        solve();
    }

    return 0;   
}
