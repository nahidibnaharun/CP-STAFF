void solve() {
    string s;
    cin >> s;

    ll cnt = 0;
    map<char, ll> freq;

    for (char c : s) {
        if (freq[c] == 0) cnt++;
        freq[c]++;
    }

    if (cnt == 1) {
        cout << -1 << '\n';
    } else {
        cout << s.size() - 1 << '\n';
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int tc;
    cin >> tc;

    while (tc--) {
        solve();
    }

    return 0;
}
