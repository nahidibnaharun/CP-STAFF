void solve() {
    ll n, k;
    cin >> n >> k;

    vector<ll> v(n);
    for (ll i = 0; i < n; i++) cin >> v[i];

    sort(v.begin(), v.end());

    auto ok = [&](ll mid) {
        ll sum = 0;
        for (ll i = 0; i < n; i++) {
            sum += min(v[i], mid);
        }
        return sum >= k;
    };

    ll l = 0, r = 1e9 + 5;

    while (l < r) {
        ll mid = l + (r - l) / 2;
        if (ok(mid)) r = mid;
        else l = mid + 1;
    }

    ll ans = k;
    for (ll i = 0; i < n; i++) {
        if (v[i] < r) ans++;
    }

    cout << ans;

}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
