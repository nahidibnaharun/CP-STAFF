void solve(){
     int n;
    cin >> n;

    vector<int> a(n + 1), f1(n + 1), f2(n + 1);

    for(int i = 1; i <= n; i++){
        cin >> a[i];
    }

    for(int i = n; i >= 1; i--){
        f1[i] = f2[i] = 0;

        for(int j = i + 1; j <= n; j++){
            f1[i] += (a[i] > a[j]);
            f2[i] += (a[i] < a[j]);
        }

        f1[i] = max(f1[i], f2[i]);
    }

    for(int i = 1; i < n; i++){
        cout << f1[i] << " ";
    }
    cout << f1[n];
}

int main(){
    ios_base::sync_with_stdio(false);
	cin.tie(NULL);
    
    ll tt; cin >> tt;
    while(tt--){
        solve();
        cout << endl;
    }
    
    
    return 0;   
}
