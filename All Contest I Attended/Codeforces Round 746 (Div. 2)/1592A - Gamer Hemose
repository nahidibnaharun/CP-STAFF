void solve()
{
ll n, H;
cin >> n >> H;
vector<ll> a(n);
for (ll i = 0; i < n; i++)
cin >> a[i];
sort(a.begin(), a.end());
ll ans = 0;
ll big = a[n - 1];
ll second = a[n - 2];
ans = (H / (big + second)) * 2;
H %= (big + second);
if (H > 0)
{
ans++;
H -= big;
}
if (H > 0)
ans++;
cout << ans << '\n';
}
int main()
{
ios_base::sync_with_stdio(false);
