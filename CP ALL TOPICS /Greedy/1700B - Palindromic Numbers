void solve()
{
ll n;
cin >> n;
string s;
cin >> s;
string res;
// Case 1: first digit is not '9'
if (s[0] != '9')
{
for (ll i = 0; i < n; i++)
{
res.push_back(char('9' - s[i] + '0'));
}
cout << res << '\n';
return;
}
string t(n + 1, '1'); // "111...111"
reverse(s.begin(), s.end());
reverse(t.begin(), t.end());
int carry = 0;
for (ll i = 0; i < (ll)t.size(); i++)
{
int x = t[i] - '0';
int y = (i < (ll)s.size() ? s[i] - '0' : 0);
int cur = x - y - carry;
if (cur < 0)
{
cur += 10;
carry = 1;
}
else
carry = 0;
res.push_back(char(cur + '0'));
}
while (res.size() > 1 && res.back() == '0')
res.pop_back();
reverse(res.begin(), res.end());
cout << res << '\n';
}
int main()
{
ios_base::sync_with_stdio(false);
cin.tie(nullptr);
int t;
cin >> t;
while (t--)
{
solve();
}
return 0;
}
