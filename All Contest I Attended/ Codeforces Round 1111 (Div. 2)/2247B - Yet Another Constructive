void solve() {
    ll n, k, m;
    cin >> n >> k >> m;

    if (k > m) {
        cout << "NO\n";
        return;
    }

    cout << "YES\n";
    for (ll i = 0; i < n; i++) {
        cout << (i % k == 0 ? m - k + 1 : 1) << ' ';
    }
    cout << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int tc;
    cin >> tc;

    while (tc--) {
        solve();
    }

    return 0;
}
