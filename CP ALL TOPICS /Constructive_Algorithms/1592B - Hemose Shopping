void solve()
{
ll n, x;
cin >> n >> x;
vector<ll> a(n), b;
for (ll i = 0; i < n; i++)
cin >> a[i];
b = a;
sort(b.begin(), b.end());
bool ok = true;
for (ll i = 0; i < n; i++) {
if (abs(i - (n - 1)) >= x || abs(i - 0) >= x)
continue;
else if (a[i] == b[i])
continue;
else
ok = false;
}
cout << (ok ? "YES\n" : "NO\n");
}
int main()
{
ios_base::sync_with_stdio(false);
