#include <bits/stdc++.h>
using namespace std;

void solve()
{
    int n;
    cin >> n;

    string s;
    cin >> s;

    int u = 0;
    for (int i = 0; i < n; i++)
    {
        bool fl = (s[i] == '1') && u;
        u ^= (s[i] - '0');
        if (i != 0) cout << (fl ? '-' : '+');
    }
    cout << '\n';
}

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) solve();
    return 0;
}
