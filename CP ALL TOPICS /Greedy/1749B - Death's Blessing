void solve()
{
ll n;
cin >> n;
vector<ll> a(n), b(n);
ll sumA = 0, sumB = 0, mxB = 0;
for (ll i = 0; i < n; i++)
{
cin >> a[i];
sumA += a[i];
}
for (ll i = 0; i < n; i++)
{
cin >> b[i];
sumB += b[i];

mxB = max(mxB, b[i]);
}
cout << sumA + sumB - mxB << '\n';
}
