void solve() {
    ll n, k;
    cin >> n >> k;

    string s, s2;
    cin >> s;

    s2 = s;

    for (ll i = k; i < n; i++) {
        s[i] = s[i - k];
    }

    if (s < s2) {
        for (ll i = k - 1; i >= 0; i--) {
            if (s[i] != '9') {
                s[i]++;
                break;
            }
            else {
                s[i] = '0';
            }
        }
    }

    for (ll i = k; i < n; i++) {
        s[i] = s[i - k];
    }

    cout << n << '\n';
    cout << s;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
