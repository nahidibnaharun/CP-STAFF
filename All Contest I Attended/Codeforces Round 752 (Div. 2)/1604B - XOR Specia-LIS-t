void solve() {
    ll n;
    cin >> n;

    vector<ll> v(n);

    for(ll i = 0; i < n; i++) {
        cin >> v[i];
    }

    if(n % 2 == 0) {
        cout << "YES";
        return;
    }

    bool ok = false;

    for(ll i = 1; i < n; i++) {
        if(v[i] <= v[i - 1]) {
            ok = true;
            break;
        }
    }

    cout << (ok ? "YES" : "NO");
}






int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
