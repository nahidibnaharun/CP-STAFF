void solve() {
    ll n;
    cin >> n;

    vector<pair<ll, ll>> v(n);
    for (ll i = 0; i < n; i++) {
        cin >> v[i].first >> v[i].second;
    }

    sort(v.begin(), v.end(), [](pair<ll, ll> a, pair<ll, ll> b) {
        ll mx1 = max(a.first, a.second);
        ll mx2 = max(b.first, b.second);

        if (mx1 == mx2) {
            return min(a.first, a.second) < min(b.first, b.second);
        }
        return mx1 < mx2;
    });

    for (auto u : v) {
        cout << u.first << ' ' << u.second << ' ';
    }

    cout << endl;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
