int a[MAX];

void solve() {
    int n;
    cin >> n;

    for (int i = 1; i <= n; i++) {
        cin >> a[i];
    }

    int pos = 0;

    for (int i = 1; i < n; i++) {
        if (a[i] > a[i + 1]) {
            pos = i;
            break;
        }
    }

    if (pos == 0) {
        cout << "Yes\n";
        return;
    }

    bool ok = true;

    for (int i = pos + 1; i <= n; i++) {
        int j = (i % n) + 1;

        if (a[i] > a[j]) {
            ok = false;
            break;
        }
    }

    cout << (ok ? "Yes\n" : "No\n");
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
