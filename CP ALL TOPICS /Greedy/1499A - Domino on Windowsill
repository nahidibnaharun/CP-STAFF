void solve() {
    int n, k1, k2;
    cin >> n >> k1 >> k2;

    int w, b;
    cin >> w >> b;

    if (k1 + k2 >= 2 * w && (n - k1) + (n - k2) >= 2 * b)
        cout << "YES";
    else
        cout << "NO";
}

