void solve() {
    
    ll n;
    cin >> n;

    string s;
    cin >> s;

    string t(n + 1, '0');

    ll ans = 0;
    ll max_1 = 0;
    ll max_2 = 0;

    for(ll i = 0; i <= n / 2 - 1; ++i){

        if(s[i] == s[n - i - 1]){
            max_2++;
        }
        else{
            ans++;
        }
    }

    if(n % 2 == 1){
        max_1++;
    }

    for(ll j = 0; j <= max_2; ++j){

        for(ll k = 0; k <= max_1; ++k){

            t[ans + j * 2 + k] = '1';
        }
    }

    cout << t;
}






    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while(t--){
        solve();
        cout << endl;
    }

    return 0;
}
