void solve() {
    ll p,a,b,c;
    cin >> p >> a >> b >> c;

    ll ans = 1e18;

    if(p % a == 0) ans = 0;
    else ans = min(ans, a - (p % a));

    if(p % b == 0) ans = 0;
    else ans = min(ans, b - (p % b));

    if(p % c == 0) ans = 0;
    else ans = min(ans, c - (p % c));

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--){
        solve();
        cout << endl;
    }

    return 0;
}
