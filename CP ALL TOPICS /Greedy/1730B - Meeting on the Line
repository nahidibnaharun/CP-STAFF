void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        vector<int> x(n), ti(n);

        for (int i = 0; i < n; i++)
            cin >> x[i];

        for (int i = 0; i < n; i++)
            cin >> ti[i];

        vector<int> a;

        for (int i = 0; i < n; i++)
        {
            a.push_back(x[i] + ti[i]);
            a.push_back(x[i] - ti[i]);
        }

        int mn = a[0], mx = a[0];

        for (int val : a)
        {
            mn = min(mn, val);
            mx = max(mx, val);
        }

        int sum = mn + mx;

        cout << sum / 2;

        if (sum % 2 != 0)
            cout << ".5";

        cout << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
