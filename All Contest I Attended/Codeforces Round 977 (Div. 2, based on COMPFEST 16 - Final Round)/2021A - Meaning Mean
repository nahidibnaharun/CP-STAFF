void solve() {
    int n;
    cin >> n;

    vector<ll> v(n, 0);

    for(int i = 0; i < n; i++) {
        cin >> v[i];
    }

    sort(v.begin(), v.end(), greater<ll>());

    while(v.size() > 1) {
        ll x = v.back();
        v.pop_back();

        ll y = v.back();
        v.pop_back();

        v.push_back((x + y) / 2);
    }

    cout << v[0];
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
