void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        vector<int> a(n + 1);

        for (int i = 1; i <= n; i++)
        {
            cin >> a[i];

            if (a[i] == n)
            {
                swap(a[1], a[i]);
            }
        }

        for (int i = 1; i <= n; i++)
        {
            cout << a[i] << " ";
        }

        cout << "\n";
    }
}

