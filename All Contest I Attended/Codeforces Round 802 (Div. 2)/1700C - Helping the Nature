void solve()
{
ll n;
cin >> n;
vector<ll> a(n);
for (ll i = 0; i < n; i++)
cin >> a[i];
ll jog = 0, prejog = 0;
bool need = false;
for (ll i = 0; i < n; i++)
{
if (need)
{
ll cur = a[i] - jog;
ll prev = a[i - 1];
ll diff = abs(prev - cur);
jog += diff;
a[i] = prev;
need = false;
}
else
{
a[i] -= jog;
}
if (i + 1 < n)
{
ll x = a[i];
ll y = a[i + 1] - jog;
if (x < y)
need = true;
else
prejog += abs(x - y);
}
}
cout << prejog + jog + abs(a[n - 1]) << '\n';
}
int main()
{
ios_base::sync_with_stdio(false);
cin.tie(nullptr);
int t;
cin >> t;
while (t--)
{
solve();
}
return 0;
}
