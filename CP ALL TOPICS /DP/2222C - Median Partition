void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n + 1), b(n + 1), dp(n + 1, 0);

    for (ll i = 1; i <= n; i++) cin >> a[i];

    // copy and sort
    for (ll i = 1; i <= n; i++) b[i] = a[i];
    sort(b.begin() + 1, b.begin() + n + 1);

    ll mid = b[(n + 1) >> 1];

    for (ll i = 1; i <= n; i++) {
        if (a[i] == mid) {
            a[i] = 0;
        } else {
            a[i] = (a[i] > mid ? 1 : -1);
        }
    }

    for (ll i = 1; i <= n; i++) {
        ll flg = 0;
        dp[i] = 0;

        flg = !a[i];

        if (flg && (i == 1 || dp[i - 1])) {
            dp[i] = dp[i - 1] + 1;
        }

        for (ll j = i - 3, sm = a[i]; j >= 0; j -= 2) {
            flg += !a[j + 1];
            flg += !a[j + 2];
            sm += a[j + 1] + a[j + 2];

            if (abs(sm) >= flg || (j && !dp[j])) continue;

            dp[i] = max(dp[i], dp[j] + 1);
        }
    }

    cout << dp[n];
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
