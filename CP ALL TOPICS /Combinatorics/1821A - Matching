void solve() {
    string s;
    cin >> s;

    ll ans = 1;

    if (s[0] == '0') {
        ans = 0;
    }
    else if (s[0] == '?') {
        ans = 9;
    }

    for (ll i = 1; i < s.size(); i++) {
        if (s[i] == '?') {
            ans *= 10;
        }
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
