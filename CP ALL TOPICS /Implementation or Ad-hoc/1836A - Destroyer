void solve() {
      
          ll n;
    cin >> n;

    vector<ll> cnt(n + 1, 0);

    for (ll i = 0; i < n; i++) {
        ll d;
        cin >> d;
        if (d < n) {
            cnt[d]++;
        } else {
            cnt[n] = MAX;
        }
    }

    bool good = true;
    for (ll i = 1; i <= n; i++) {
        if (cnt[i] > cnt[i - 1]) {
            good = false;
            break;
        }
    }

    cout << (good ? "YES" : "NO");

}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
