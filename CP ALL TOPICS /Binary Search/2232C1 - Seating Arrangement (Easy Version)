ll s, t;

ll eval(string &S, int m) {
    ll T = 0, ans = 0;

    for(char c : S) {
        if(c == 'I') {
            if(T < t) {
                T++;
                ans++;
            }
        }
        else if(c == 'E') {
            if(ans < T * s) {
                ans++;
            }
        }
        else {
            if(m > 0) {
                m--;

                if(T < t) {
                    T++;
                    ans++;
                }
            }
            else {
                if(ans < T * s) {
                    ans++;
                }
            }
        }
    }

    return ans;
}

void solve() {
    int n;
    cin >> n >> t >> s;

    string S;
    cin >> S;

    int l = 0, r = 0;

    for(char c : S) {
        if(c == 'A') {
            r++;
        }
    }

    ll ans = 0;

    for(int i = l; i <= r; i++) {
        ans = max(ans, eval(S, i));
    }

    cout << ans;
}





    
