int cnt[MAX];

void solve() {
    int n;
    cin >> n;

    int cnt2 = 0, cnt4 = 0;

    for (int i = 1; i <= n; i++) {
        int x;
        cin >> x;

        cnt2 -= cnt[x] / 2;
        cnt4 -= cnt[x] / 4;

        cnt[x]++;

        cnt2 += cnt[x] / 2;
        cnt4 += cnt[x] / 4;
    }

    int q;
    cin >> q;

    while (q--) {
        char type;
        int x;
        cin >> type >> x;

        cnt2 -= cnt[x] / 2;
        cnt4 -= cnt[x] / 4;

        if (type == '+') {
            cnt[x]++;
        }
        else {
            cnt[x]--;
        }

        cnt2 += cnt[x] / 2;
        cnt4 += cnt[x] / 4;

        if (cnt4 >= 1 && cnt2 >= 4) {
            cout << "YES\n";
        }
        else {
            cout << "NO\n";
        }
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
