void solve() {
    int n;
    cin >> n;

    vector<int> arr(n);

    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    int mn = 1000000010;
    int mx = -1000000010;

    for (int i = 0; i < n; i++) {
        if (i > 0 && arr[i] == -1 && arr[i - 1] != -1) {
            mn = min(mn, arr[i - 1]);
            mx = max(mx, arr[i - 1]);
        }

        if (i < n - 1 && arr[i] == -1 && arr[i + 1] != -1) {
            mn = min(mn, arr[i + 1]);
            mx = max(mx, arr[i + 1]);
        }
    }

    int res = (mx + mn) / 2;
    int ans = 0;

    for (int i = 0; i < n; i++) {
        if (arr[i] == -1) {
            arr[i] = res;
        }

        if (i) {
            ans = max(ans, abs(arr[i] - arr[i - 1]));
        }
    }

    cout << ans << " " << res;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
