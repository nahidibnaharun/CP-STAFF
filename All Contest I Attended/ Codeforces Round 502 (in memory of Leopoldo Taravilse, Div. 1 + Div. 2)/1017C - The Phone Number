void solve() {
    ll n;
    cin >> n;

    ll L = sqrt(n);
    vector<ll> A(n + 1);

    for(ll i = 1, o = n, j; i <= n; i += L) {
        for(j = min(i + L - 1, n); j >= i; j--) {
            A[j] = o--;
        }
    }

    for(ll i = 1; i <= n; i++) {
        cout << A[i];
        if(i < n) cout << ' ';
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
