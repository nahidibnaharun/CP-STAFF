void solve() {
    ll n, C;
    cin >> n >> C;

    ll ans = 0;
    vector<ll> a(n), b(n);

    for (ll i = 0; i < n; i++)
        cin >> a[i];

    for (ll i = 0; i < n; i++)
        cin >> b[i];

    bool needReorder = false;

    for (ll i = 0; i < n; i++) {
        if (a[i] < b[i])
            needReorder = true;

        ans += a[i];
        ans -= b[i];
    }

    if (needReorder) {
        needReorder = false;
        ans += C;

        sort(a.begin(), a.end());
        sort(b.begin(), b.end());

        for (ll i = 0; i < n; i++) {
            if (a[i] < b[i])
                needReorder = true;
        }
    }

    if (needReorder)
        cout << -1;
    else
        cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
