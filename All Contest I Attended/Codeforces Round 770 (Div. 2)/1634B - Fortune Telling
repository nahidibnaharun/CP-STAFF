void solve()
{
    ll n, x, y;
    cin >> n >> x >> y;

    ll sum = 0;

    for (int i = 0; i < n; i++)
    {
        ll v;
        cin >> v;
        sum += v;
    }

    if ((sum + x + y) % 2 == 0)
        cout << "Alice\n";
    else
        cout << "Bob\n";
}

