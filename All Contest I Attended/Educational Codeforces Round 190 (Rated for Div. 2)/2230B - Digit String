void solve() {
    string s;
    cin >> s;

    ll n = s.size();

    ll cnt = 0;
    ll cnt1 = 0, cnt2 = 0, cnt3 = 0, cnt4 = 0;

    for(ll i = 0; i < n; i++) {
        if(s[i] == '1') cnt1++;
        if(s[i] == '2') cnt2++;
        if(s[i] == '3') cnt3++;
        if(s[i] == '4') cnt4++;
    }

    ll ans = cnt4 + cnt2;

    for(ll i = 0; i < n; i++) {
        if(s[i] == '1') cnt++;
        if(s[i] == '3') cnt++;
        if(s[i] == '2') cnt2--;

        ans = min(ans, cnt4 + cnt2 + cnt);
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
