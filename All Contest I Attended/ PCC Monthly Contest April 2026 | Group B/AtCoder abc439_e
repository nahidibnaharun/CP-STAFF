void solve(){
    int n; cin >> n;
    vector<pair<int,int>>k(n);
    for(auto &x:k)cin >> x.first>>x.second;
 

sort(k.begin() , k.end() , [](const pair<int,int> & a, const pair<int,int> & b){
    if(a.first !=b.first)return a.first<b.first;
    return a.second>b.second;
});
   
    
 vector<int>tl;
 for(int i=0 ;i<n;i++){
    int vl=k[i].second; 
    auto it=lower_bound(tl.begin(),tl.end(),vl);
    if(it==tl.end())tl.push_back(vl);
    else *it=vl;
 }
    cout << tl.size();
} 



    
