void solve() {
    int n;
    cin >> n;

    if (n % 2) {
        if (n < 27) {
            cout << -1;
        }
        else {
            vector<int> ar(n + 1);

            ar[1] = ar[26] = 1;
            ar[2] = ar[11] = ar[27] = 2;

            int cnt = 3;

            for (int i = 3; i < 11; i += 2) {
                ar[i] = ar[i + 1] = cnt;
                cnt++;
            }

            for (int i = 12; i < 26; i += 2) {
                ar[i] = ar[i + 1] = cnt;
                cnt++;
            }

            for (int i = 28; i < n; i += 2) {
                ar[i] = ar[i + 1] = cnt;
                cnt++;
            }

            for (int i = 1; i <= n; i++) {
                cout << ar[i] << " ";
            }
        }
    }
    else {
        for (int i = 1; i <= n / 2; i++) {
            cout << i << " " << i << " ";
        }
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
