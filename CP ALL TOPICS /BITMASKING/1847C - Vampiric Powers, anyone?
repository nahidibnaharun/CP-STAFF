void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n);

    for(auto &i : a) {
        cin >> i;
    }

    ll max_value = (1 << 8);

    vector<char> has_pref(max_value);

    has_pref[0] = true;

    ll cur_xor = 0;
    ll ans = 0;

    for(auto i : a) {
        cur_xor ^= i;

        for(ll pref = 0; pref < max_value; pref++) {
            if(has_pref[pref]) {
                ans = max(ans, pref ^ cur_xor);
            }
        }

        has_pref[cur_xor] = true;
    }

    cout << ans;
}






int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
