ll n,m,a[MAX],b[MAX];
string s,s2;

void solve() {
    cin >> n >> m;
    cin >> s >> s2;

    ll j = 0;

    for(ll i=0;i<m;i++){
        while(j<n){
            if(s2[i] == s[j]){
                a[i] = j;
                j++;
                break;
            }
            j++;
        }
    }

    ll ans = 0;
    j = n-1;

    for(ll i=m-1;i>=0;i--){
        ll x = a[i];
        ll y = 0;

        while(j>=x){
            if(s[j] == s2[i]){
                y = j;
                j--;
                break;
            }
            j--;
        }

        if(i > 0){
            ans = max(ans, y - a[i-1]);
        }
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
