void solve()
{
    ll b, p, f;
    cin >> b >> p >> f;

    ll h, c;
    cin >> h >> c;

    b /= 2;

    if (h < c)
    {
        swap(h, c);
        swap(p, f);
    }

    ll res = 0;

    ll cnt = min(b, p);
    b -= cnt;
    p -= cnt;
    res += h * cnt;

    cnt = min(b, f);
    b -= cnt;
    f -= cnt;
    res += c * cnt;

    cout << res << "\n";
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--)
    {
        solve();
    }

    return 0;
}
