vector<vector<ll>> pref(MAX, vector<ll>(31));

void solve() {

    ll l, r;
    cin >> l >> r;

    ll total = r - l + 1;
    ll ans = total;

    for(int i = 0; i < 31; i++) {

        ll temp = pref[r][i] - pref[l - 1][i];

        ans = min(ans, total - temp);
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    for(int i = 1; i <= 200000; i++) {

        for(int j = 0; j < 31; j++) {

            if(i & (1 << j)) {
                pref[i][j]++;
            }
        }

        for(int j = 0; j < 31; j++) {
            pref[i][j] += pref[i - 1][j];
        }
    }

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
