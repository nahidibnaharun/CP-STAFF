#include <bits/stdc++.h>
using namespace std;

using ll = long long;
using ull = unsigned long long;
using ld = long double;
using ui = unsigned int;

const int INF = 1e9 + 5;
const int MOD = 1000000007;
const int MAX = 200005;

ll n, a[MAX], b[MAX], mn[MAX];

void solve() {
    cin >> n;

    map<ll, ll> pos;

    for (ll i = 1; i <= n; i++) {
        cin >> a[i];
        mn[i] = INF;
        pos[a[i]] = i;
    }

    for (ll i = 1; i <= n; i++) {
        cin >> b[i];
    }

    mn[0] = INF;

    for (ll i = 2; i <= 2 * n; i += 2) {
        mn[i] = min(mn[i - 2], pos[i - 1]);
    }

    ll ans = INF;

    for (ll i = 1; i <= n; i++) {
        ans = min(ans, (i - 1) + (mn[b[i]] - 1));
    }

    cout << ans << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
