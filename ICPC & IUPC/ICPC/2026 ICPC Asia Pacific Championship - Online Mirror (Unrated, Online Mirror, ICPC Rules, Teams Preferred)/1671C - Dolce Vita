void solve() {
    ll n;
    cin >> n;

    vector<ll> v(n);

    ll cnt = 0;
    ll y = 0;

    for (int i = 0; i < n; i++) {
        cin >> v[i];

        if (i > 0) {
            ll x = abs(v[i] - v[i - 1]);
            y += x;
            cnt = __gcd(cnt, x);
        }
    }

    ll z = v[0];

    if (cnt > 0) {
        ll c = 2 * cnt;
        z = v[0] % c;

        if (z <= 0) {
            z += c;
        }
    }

    cout << z + y << '\n';
}

