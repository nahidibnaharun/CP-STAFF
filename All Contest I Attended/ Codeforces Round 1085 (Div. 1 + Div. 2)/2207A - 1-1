void solve(){

ll n; cin >> n;
    string s; cin >> s;

    for(ll i = 1; i < n - 1; i++){
        if(s[i-1] == '1' && s[i+1] == '1'){
            s[i] = '1';
        }
    }

    ll ans1 = 0;
    for(ll i = 0; i < n; i++){
        if(s[i] == '1') ans1++;
    }

    for(ll i = 1; i < n - 1; i++){
        if(s[i-1] == '1' && s[i+1] == '1'){
            s[i] = '0';
        }
    }

    for(ll i = 1; i < n - 1; i++){
        if(s[i-1] == '1' && s[i+1] == '1'){
            s[i] = '0';
        }
    }

    ll ans = 0;
    for(ll i = 0; i < n; i++){
        if(s[i] == '1') ans++;
    }

    cout << ans << " " << ans1;
}
 
int main(){
    ios_base::sync_with_stdio(false);
	cin.tie(NULL);
    
    ll Test_Case; cin >> Test_Case;
    while(Test_Case--){
        solve();
        cout << endl;
    }
    
    
    return 0;   
