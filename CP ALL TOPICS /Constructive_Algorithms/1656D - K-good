void solve() {
    ll n;
    cin >> n;

    ll x = n;

    while (x % 2 == 0) {
        x /= 2;
    }

    if (x == 1) {
        cout << -1;
    }
    else if (x <= 2000000000LL && (x * (x + 1)) / 2 <= n) {
        cout << x;
    }
    else {
        cout << 2 * (n / x);
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
