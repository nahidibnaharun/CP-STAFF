inline bool get_bit(ui x, ui bt) { return (x >> bt) & 1; }
inline void make_one(ui &x, ui bt) { x |= (1U << bt); }
inline void make_null(ui &x, ui bt) { x &= (~(1U << bt)); }

bool solve_bit(vector<ui> &ans,
               vector<vector<pair<ui, ui>>> &g,
               ui bt) {

    for (ui i = 0; i < ans.size(); ++i) {
        for (auto &it : g[i]) {
            if (!get_bit(it.second, bt))
                make_null(ans[i], bt);
            else if (!get_bit(ans[i], bt) && !get_bit(ans[it.first], bt))
                return false;
        }
    }

    for (ui i = 0; i < ans.size(); ++i) {
        if (get_bit(ans[i], bt)) {
            make_null(ans[i], bt);
            for (auto &it : g[i]) {
                if (!get_bit(ans[it.first], bt) && get_bit(it.second, bt)) {
                    make_one(ans[i], bt);
                    break;
                }
            }
        }
    }

    return true;
}

void solve() {
    
    ui n, m;
    cin >> n >> m;

    vector<vector<pair<ui, ui>>> g(n);

    while (m--) {
        ui a, b, c;
        cin >> a >> b >> c;
        a--, b--;

        g[a].push_back({b, c});
        g[b].push_back({a, c});
    }

    const ui pt = 31;

    vector<ui> ans(n, ~(1U << pt));

    for (ui i = 0; i < pt; ++i) {
        if (!solve_bit(ans, g, i)) {
            cout << -1 << '\n';
            return;
        }
    }

    for (auto &it : ans) {
        cout << it << " ";
    }
    cout << '\n';
}

