void solve() {

    int n;
    cin >> n;

    string a, b;
    cin >> a >> b;

    if(a == b) {
        cout << 0;
        return;
    }

    pair<int, int> xy = {
        count(a.begin(), a.end(), '0'),
        count(a.begin(), a.end(), '1')
    };

    pair<int, int> xp_yp = {
        xy.second - 1,
        xy.first + 1
    };

    pair<int, int> fx_fy = {
        count(b.begin(), b.end(), '0'),
        count(b.begin(), b.end(), '1')
    };

    if((fx_fy != xy) && (fx_fy != xp_yp)) {
        cout << -1;
        return;
    }

    int mis_match = 0;

    for(int i = 0; i < n; i++) {
        if(a[i] != b[i]) {
            mis_match++;
        }
    }

    int ans = 0;

    if(fx_fy == xp_yp) {

        ans++;
        ans += (n - 1 - mis_match);

        if(fx_fy == xy) {
            cout << min(mis_match, ans);
            return;
        }

        cout << ans;
        return;
    }

    cout << mis_match;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
