void solve() {
    ll n;
    string s, t;

    cin >> n >> s >> t;

    ll ans = 0;

    for(ll i = 0; i < n / 2; i++) {
        map<char, ll> a;

        a[s[i]]++;
        a[s[n - i - 1]]++;
        a[t[i]]++;
        a[t[n - i - 1]]++;

        if(a.size() == 4) {
            ans += 2;
        }

        else if(a.size() == 3) {
            ans += 1 + (s[i] == s[n - i - 1]);
        }

        else if(a.size() == 2) {
            ans += (a[s[i]] != 2);
        }
    }

    if(n % 2 == 1 && s[n / 2] != t[n / 2]) {
        ans++;
    }

    cout << ans;
}






int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while(t--){
        solve();
        cout << endl;
    }

    return 0;
}
