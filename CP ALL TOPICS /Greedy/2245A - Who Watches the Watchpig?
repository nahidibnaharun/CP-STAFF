void solve() {
    ll n, k;
    cin >> n >> k;

    string s;
    cin >> s;

    if (k * 2 > n) {
        cout << -1 << '\n';
        return;
    }

    ll ans = 0;
    for (ll i = 0; i < k; i++) {
        ans += (s[i] != 'R');
        ans += (s[n - i - 1] != 'L');
    }

    cout << ans << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int tc;
    cin >> tc;

    while (tc--) {
        solve();
    }

    return 0;
}
