#include<bits/stdc++.h>
using namespace std;
#define lli long long int
#define flash_all ios_base::sync_with_stdio(0);cin.tie(0);cout.tie(0);

int main()
{
    flash_all;

    int n,i,idx=-1;
    lli ans=-1,val;

    cin>>n;

    lli a[n],pre[n],suf[n];

    for(i=0; i<n; i++)
        cin>>a[i];

    for(i=0; i<n; i++)
    {
        pre[i]=~a[i];

        if(i)
            pre[i]&=pre[i-1];
    }

    for(i=n-1; i>=0; i--)
    {
        suf[i]=~a[i];

        if(i<n-1)
            suf[i]&=suf[i+1];
    }

    for(i=0; i<n; i++)
    {
        if(i==0)
            val=suf[i+1]&a[i];

        else if(i==n-1)
            val=pre[i-1]&a[i];

        else
            val=pre[i-1]&suf[i+1]&a[i];

        if(val>ans)
        {
            ans=val;
            idx=i;
        }
    }

    cout<<a[idx];

    for(i=0; i<n; i++)
    {
        if(i==idx)
            continue;

        cout<<' '<<a[i];
    }

    return 0;
}
