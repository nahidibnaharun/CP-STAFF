void solve()
{
ll n;
cin >> n;
ll ans = 0;
ll prv = 0, ok = 0;
for (ll i = 1; i <= n; i++)
{
ll a;
cin >> a;
ans += (a != prv);
ok |= (a == prv);
if (prv + 1 < a)
{
ans += ok;
ok = 0;
}
prv = a;
}
ans += ok;
cout << ans << "\n";
}
int main()
{
ios_base::sync_with_stdio(false);
cin.tie(nullptr);
int t;
cin >> t;
while (t--)
solve();
return 0;
}
