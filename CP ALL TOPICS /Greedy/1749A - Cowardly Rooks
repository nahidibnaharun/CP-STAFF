void solve()
{
ll n, m;
cin >> n >> m;
vector<pair<ll, ll>> a(m);
for (ll i = 0; i < m; i++)
{
cin >> a[i].first >> a[i].second;
a[i].first--;
a[i].second--;
}
bool ans = false;

for (ll i = 0; i < m; i++)
{
for (ll x = 0; x < n; x++)
{
for (ll y = 0; y < n; y++)
{
if ((x == a[i].first) ^ (y == a[i].second))
{
bool ok = true;
for (ll j = 0; j < m; j++)
{
if (i != j)
{
ok &= (x != a[j].first && y != a[j].second);
}
}
ans |= ok;
}
}
}
}
cout << (ans ? "YES\n" : "NO\n");
}
int main()
{
ios_base::sync_with_stdio(false);
cin.tie(nullptr);
int t;
cin >> t;
while (t--)
{
solve();
}
return 0;
}
