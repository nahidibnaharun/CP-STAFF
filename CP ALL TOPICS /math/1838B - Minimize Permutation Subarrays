ll idx[MAX];

void solve() {
    ll n;
    cin >> n;

    for(ll i = 1; i <= n; i++) {
        ll x;
        cin >> x;
        idx[x] = i;
    }

    if(idx[n] < min(idx[1], idx[2])) {
        cout << idx[n] << " " << min(idx[1], idx[2]);
    } 
    else if(idx[n] > max(idx[1], idx[2])) {
        cout << idx[n] << " " << max(idx[1], idx[2]);
    } 
    else {
        cout << idx[1] << " " << idx[2];
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout << endl;
    }

    return 0;
}
