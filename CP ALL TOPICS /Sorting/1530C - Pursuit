void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n), b(n);
    ll me = 0, you = 0;

    for(ll i = 0; i < n; i++) {
        cin >> a[i];
        me += a[i];
    }

    for(ll i = 0; i < n; i++) {
        cin >> b[i];
        you += b[i];
    }

    sort(a.begin(), a.end());
    sort(b.begin(), b.end());

    ll k = n / 4;

    for(ll i = 0; i < k; i++) {
        me -= a[i];
        you -= b[i];
    }

    if(me >= you) {
        cout << 0 << endl;
        return;
    }

    ll x = k, y = k - 1, r = n, ans = 0, zero = 0;

    while(true) {
        if(me >= you) break;

        me += 100;
        zero++;

        if(y >= 0) {
            you += b[y];
            y--;
        }

        r++;

        if(r / 4 > k) {
            k++;
            me -= a[x];
            x++;

            if(zero < k) {
                you -= b[y + 1];
                y++;
            }
        }

        ans++;
    }

    cout << ans << endl;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
    }

    return 0;
}
