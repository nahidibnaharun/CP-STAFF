    if(a==1)vl++;
    else if(a==2){
        if(vl>=1){
            vl--;
        }
    }
    else if(a==3){
        chk = !chk;
    }
    if(chk && vl>=3)cout<<"Yes";
    else cout<<"No";
    cout<<endl;
  }
}
    
