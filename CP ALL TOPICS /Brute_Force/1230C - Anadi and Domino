void solve() {
    int n, m;
    cin >> n >> m;

    vector<pair<int,int>> e(m);

    for (int i = 0; i < m; i++) {
        cin >> e[i].first >> e[i].second;
        e[i].first--;
        e[i].second--;
    }

    vector<int> p(n);

    for (int i = 0; i < n; i++) {
        p[i] = i % 6;
    }

    int ans = 0;

    sort(p.begin(), p.end());

    do {
        set<pair<int,int>> st;

        for (auto [a, b] : e) {
            int x = p[a];
            int y = p[b];

            if (x > y) {
                swap(x, y);
            }

            st.insert({x, y});
        }

        ans = max(ans, (int)st.size());

    } while (next_permutation(p.begin(), p.end()));

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
