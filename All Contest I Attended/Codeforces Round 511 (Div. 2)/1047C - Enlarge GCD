#include <bits/stdc++.h>
using namespace std;
using ll = long long;
using ull = unsigned long long;
using ld = long double;
using ui = unsigned int;

const ll INF = 1e18;
const int MOD = 1000000007;
const int MAXN = 15000001;

unordered_map<ll, ll> mpp;
ll spf[MAXN];

ll gcdll(ll a, ll b) {
    return (a == 0 ? b : gcdll(b % a, a));
}

void sieve() {
    spf[1] = 1;

    for (ll i = 2; i < MAXN; i++) {
        spf[i] = i;
    }

    for (ll i = 4; i < MAXN; i += 2) {
        spf[i] = 2;
    }

    for (ll i = 3; i * i < MAXN; i++) {
        if (spf[i] == i) {
            for (ll j = i * i; j < MAXN; j += i) {
                if (spf[j] == j) {
                    spf[j] = i;
                }
            }
        }
    }
}

vector<ll> getFactorization(ll x) {
    vector<ll> ret;

    while (x != 1) {
        ret.push_back(spf[x]);
        x /= spf[x];
    }

    return ret;
}

void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n);
    ll g = 0;

    for (ll i = 0; i < n; i++) {
        cin >> a[i];
        g = gcdll(a[i], g);
    }

    sieve();

    for (ll i = 0; i < n; i++) {
        vector<ll> p = getFactorization(a[i] / g);
        set<ll> s;

        for (ll x : p) {
            s.insert(x);
        }

        for (ll x : s) {
            mpp[x]++;
        }
    }

    ll ans = INF;

    for (auto [prime, cnt] : mpp) {
        ans = min(ans, n - cnt);
    }

    if (ans == INF) {
        cout << -1;
    } else {
        cout << ans;
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
