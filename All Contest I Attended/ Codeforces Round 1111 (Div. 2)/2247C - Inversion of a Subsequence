void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n), b(n);

    for (ll &x : a) cin >> x;
    for (ll &x : b) cin >> x;

    if (a == b) {
        cout << 0 << '\n';
        return;
    }

    ll sum = 0;

    for (ll i = 0; i < n; i++) {
        if (a[i] != b[i]) {
            sum += a[i];
        }
    }

    if (accumulate(a.begin(), a.end(), 0LL) == 0 || accumulate(b.begin(), b.end(), 0LL) == n) {
        cout << -1 << '\n';
        return;
    }

    cout << (sum % 2 ? 1 : 2) << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int tc;
    cin >> tc;

    while (tc--) {
        solve();
    }

    return 0;
}
