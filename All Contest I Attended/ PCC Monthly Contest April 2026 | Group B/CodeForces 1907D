bool fun(ll k, vector<pair<ll,ll>> & seg)
{
    ll left=0,right=0;

    for(auto &x:seg){
        left= max(left-k,x.first);
        right = min(right+k,x.second);
        if(left>right)return false;
    }
    return true;
}

void solve(){
    int n; cin >> n;
    vector<pair<ll,ll>>seg(n);
    for(auto &x:seg)cin >> x.first>>x.second;

    ll l=-1,r=INF;

    while(r-l>1){
        ll mid=(l+r)/2;
        if(fun(mid,seg))r=mid;
        else l=mid;
    }
    cout<<r;
}



    
int main()
{
    ios_base::sync_with_stdio(false);
