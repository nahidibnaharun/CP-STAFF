const int NMAX = 1e5 + 5;

ll v[NMAX], pos[NMAX];

void solve()
{
    ll n;
    cin >> n;

    for (ll i = 0; i < n; i++)
    {
        cin >> v[i];
        pos[v[i]] = i;
    }

    ll l = pos[0], r = pos[0];
    ll ans = 1;

    for (ll i = 1; i < n; i++)
    {
        if (pos[i] < l)
        {
            l = pos[i];
        }
        else if (pos[i] > r)
        {
            r = pos[i];
        }
        else
        {
            ans = (ans * (r - l + 1 - i)) % MOD;
        }
    }

    cout << ans << '\n';
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;
    while (t--)
    {
        solve();
    }

    return 0;
}
