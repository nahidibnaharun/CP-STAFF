#include<bits/stdc++.h>
#define ll     long long
using namespace std;

#define sz 200005

ll n,a[sz];

void Solve(int t)
{
    ll i, j, fg = 0, x, y, ans = 1e10;
    cin>>n;
    for(i=1;i<=2*n;i++)
    {
        cin>>a[i];
    }
    sort(a+1,a+n+n+1);
    for(i=1;i<=2*n;i+=2)
    {
        x = (i+1)/2;
        y = (2*n-i+1)/2;
        ans = min(ans,abs(a[x]-a[x+y]));
    }
    cout<<ans<<endl;
}
int main()
{
    int t,T=1;
    scanf("%d",&T);
    for(t=1;t<=T;t++)
    {
        Solve(t);
    }
    return 0;
}
