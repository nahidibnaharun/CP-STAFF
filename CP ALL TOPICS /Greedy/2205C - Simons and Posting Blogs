int vis[MAXN];
int chg[8010];
vector<int> a[8010];

void init(vector<int> &now)
{
    for (auto &v : now)
    {
        cin >> v;
        vis[v] = 0;
    }

    reverse(now.begin(), now.end());

    vector<int> nw;

    for (auto v : now)
    {
        if (!vis[v])
        {
            nw.push_back(v);
            vis[v] = 1;
        }
    }

    for (auto v : nw)
    {
        vis[v] = 0;
    }

    now = nw;
}

void change(vector<int> &now)
{
    if (now.size() == 1 && now[0] == INT_MAX)
    {
        return;
    }

    vector<int> nw;

    for (auto v : now)
    {
        if (!vis[v])
        {
            nw.push_back(v);
        }
    }

    now = nw;
}

void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        for (int i = 1; i <= n; i++)
        {
            int x;
            cin >> x;

            a[i].resize(x);
            init(a[i]);
            chg[i] = 0;
        }

        for (int i = 1; i <= n; i++)
        {
            int id = 1;

            for (int j = 1; j <= n; j++)
            {
                if (!chg[j] && a[j] < a[id])
                {
                    id = j;
                }
            }

            auto &now = a[id];

            for (auto v : now)
            {
                cout << v << " ";
                vis[v] = 1;
            }

            now = {INT_MAX};
            chg[id] = 1;

            for (int j = 1; j <= n; j++)
            {
                if (!chg[j])
                {
                    change(a[j]);
                }
            }
        }

        cout << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
