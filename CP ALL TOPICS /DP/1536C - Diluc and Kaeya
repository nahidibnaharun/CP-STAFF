pair<int, int> getRatio(int a, int b) {
    int g = __gcd(a, b);
    a /= g;
    b /= g;
    return {a, b};
}

void solve() {
    int n;
    string s;
    cin >> n >> s;

    int d = 0, k = 0;
    map<pair<int, int>, int> freq;

    for (char c : s) {
        if (c == 'D') {
            d++;
        } else {
            k++;
        }

        cout << ++freq[getRatio(d, k)] << " ";
    }

    cout << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int tc;
    cin >> tc;

    while (tc--) {
        solve();
    }

    return 0;
}
