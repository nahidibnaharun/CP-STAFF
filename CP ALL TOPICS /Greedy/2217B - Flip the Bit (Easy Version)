void solve() {
    ll n, k;
    cin >> n >> k;

    vector<ll> arr(n + 2);
    for (ll i = 1; i <= n; i++) {
        cin >> arr[i];
    }

    ll pivot;
    cin >> pivot;

    arr[0] = arr[n + 1] = arr[pivot];

    ll countL = 0, countR = 0;

    for (ll i = 0; i < pivot; i++) {
        if (arr[i] != arr[i + 1]) {
            countL++;
        }
    }

    for (ll i = pivot; i < n + 1; i++) {
        if (arr[i] != arr[i + 1]) {
            countR++;
        }
    }

    cout << max(countL, countR);
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout << '\n';
    }

    return 0;
}
