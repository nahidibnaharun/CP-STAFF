int a[MAX];

void solve() {
    int n;
    cin >> n;

    for (int i = 1; i <= n; i++) {
        cin >> a[i];
    }

    if (n == 2) {
        cout << min(a[1], a[2]) << "\n";
        return;
    }

    int ans = min(a[1], a[2]);

    for (int i = 1; i <= n - 2; i++) {
        vector<int> temp;

        for (int j = 0; j < 3; j++) {
            temp.push_back(a[i + j]);
        }

        sort(temp.begin(), temp.end());

        ans = max(ans, temp[1]);
    }

    cout << ans << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
