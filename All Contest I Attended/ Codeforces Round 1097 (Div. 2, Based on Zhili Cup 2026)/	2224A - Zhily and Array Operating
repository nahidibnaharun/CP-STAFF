void solve() {
    int n, ans = 0;
    cin >> n;

    vector<ll> a(n + 1);
    vector<int> ANS;

    for (int i = 1; i <= n; i++) {
        cin >> a[i];
    }

    for (int i = n - 1; i >= 1; i--) {
        if (a[i + 1] > 0) {
            ANS.push_back(i);
            a[i] += a[i + 1];
        }
    }

    for (int i = 1; i <= n; i++) {
        if (a[i] > 0) ans++;
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
