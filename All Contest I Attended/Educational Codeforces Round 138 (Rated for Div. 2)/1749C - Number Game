void solve()
{
ll n;
cin >> n;
vector<ll> a(n);
for (ll &x : a)
cin >> x;
ll ans = 0;
for (ll k = 1; k <= n; k++)
{
multiset<ll> s(a.begin(), a.end());
for (ll i = 0; i < k; i++)
{
auto it = s.upper_bound(k - i);
if (it == s.begin())
break;
it--;
s.erase(it);
if (!s.empty())
{
ll x = *s.begin();
s.erase(s.begin());
s.insert(x + k - i);
}
}
if ((ll)s.size() + k == n)
ans = k;
}
cout << ans << '\n';
}
int main()
{
ios_base::sync_with_stdio(false);
cin.tie(nullptr);
int t;
cin >> t;
while (t--)
{
solve();
}
return 0;
}

