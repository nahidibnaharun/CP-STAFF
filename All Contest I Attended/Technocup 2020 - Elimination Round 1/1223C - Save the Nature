ll calc(vector<ll> &p, ll len, ll x, ll a, ll y, ll b) {
    ll ans = 0;
    ll cx = 0, cy = 0, cxy = 0;

    for (ll i = 1; i <= len; i++) {
        if (i % a == 0 && i % b == 0)
            cxy++;
        else if (i % a == 0)
            cx++;
        else if (i % b == 0)
            cy++;
    }

    for (ll i = 0; i < cxy; i++)
        ans += p[i] * (x + y);

    for (ll i = 0; i < cx; i++)
        ans += p[cxy + i] * x;

    for (ll i = 0; i < cy; i++)
        ans += p[cxy + cx + i] * y;

    return ans;
}

void solve() {
    ll n;
    cin >> n;

    vector<ll> p(n);
    for (ll i = 0; i < n; i++) {
        cin >> p[i];
        p[i] /= 100;
    }

    sort(p.rbegin(), p.rend());

    ll x, a, y, b;
    cin >> x >> a;
    cin >> y >> b;

    ll k;
    cin >> k;

    if (x < y) {
        swap(x, y);
        swap(a, b);
    }

    ll l = 0, r = n + 1;

    while (r - l > 1) {
        ll mid = (l + r) / 2;

        if (calc(p, mid, x, a, y, b) >= k)
            r = mid;
        else
            l = mid;
    }

    if (r > n)
        cout << -1;
    else
        cout << r;
}

