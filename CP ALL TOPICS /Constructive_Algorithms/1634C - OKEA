void solve()
{
    int n, k;
    cin >> n >> k;

    if (k == 1)
    {
        cout << "YES\n";
        for (int i = 1; i <= n; i++)
            cout << i << "\n";
        return;
    }

    if (n % 2 == 1)
    {
        cout << "NO\n";
        return;
    }

    cout << "YES\n";

    for (int i = 1; i <= n; i++)
    {
        for (int j = i; j <= n * k; j += n)
            cout << j << " ";
        cout << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--)
        solve();

    return 0;
}
