const int N = 1000043;

vector<int> g[N];

int color[N];
int siz[N];

int n, m;
int cc = 0;

int dfs(int x) {
    if(color[x])
        return 0;

    color[x] = cc;

    int ans = (x < n ? 1 : 0);

    for(auto y : g[x]) {
        ans += dfs(y);
    }

    return ans;
}

void solve() {
    cin >> n >> m;

    for(int i = 0; i < m; i++) {
        int k;
        cin >> k;

        for(int j = 0; j < k; j++) {
            int x;
            cin >> x;

            x--;

            g[x].push_back(i + n);
            g[i + n].push_back(x);
        }
    }

    for(int i = 0; i < n; i++) {
        if(!color[i]) {
            cc++;
            siz[cc] = dfs(i);
        }

        cout << siz[color[i]] << " ";
    }
}





    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t = 1;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
