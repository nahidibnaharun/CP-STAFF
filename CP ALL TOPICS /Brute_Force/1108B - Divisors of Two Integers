void solve() {
    int n;
    cin >> n;

    multiset<int> a;

    for (int i = 0; i < n; ++i) {
        int x;
        cin >> x;
        a.insert(x);
    }

    int x = *prev(a.end());

    for (int i = 1; i <= x; ++i) {
        if (x % i == 0) {
            a.erase(a.find(i));
        }
    }

    cout << x << " " << *prev(a.end());
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
