void solve()
{
ll n, m;
cin >> n >> m;
ll sum = 0;
// sum of 1 to m
sum += (m * (m + 1)) / 2;
// remaining rows
for (ll i = 2; i <= n; i++)
{
sum += (i * m);
}
cout << sum << '\n';
}
