ll a[MAX];

ll get(ll i){
    return max(0LL,max(a[i-1],a[i+1])-a[i]+1);
}

void solve() {
    ll n;
    cin>>n;

    for(ll i=1;i<=n;i++){
        cin>>a[i];
    }

    if(n&1){

        ll ans=0;

        for(ll i=2;i<n;i+=2){
            ans+=get(i);
        }

        cout<<ans;
        return;
    }

    ll tot=0;

    for(ll i=2;i<n;i+=2){
        tot+=get(i);
    }

    ll ans=tot;

    for(ll i=n-1;i>1;i-=2){
        tot-=get(i-1);
        tot+=get(i);

        ans=min(ans,tot);
    }

    cout<<ans;
}






int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin>>t;

    while(t--){
        solve();
        cout<<endl;
    }

    return 0;
}
