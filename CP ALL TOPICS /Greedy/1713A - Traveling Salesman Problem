void solve() {
      ll n;
    cin >> n;
    
    ll minX = 0, minY = 0, maxX = 0, maxY = 0;
    for(ll i = 0; i < n; i++) {
        ll x, y;
        cin >> x >> y;
        minX = min(x, minX);
        maxX = max(x, maxX);
        minY = min(y, minY);
        maxY = max(y, maxY);
    }
    cout << 2 * (maxX + maxY - minX - minY);

}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
