void solve() {
    ll n, m;
    cin >> n >> m;

    vector<ll> seat;
    vector<ll> chk;
    map<ll, ll> freq;

    for (ll i = 0; i < n; i++) {
        ll x;
        cin >> x;

        seat.push_back(x);

        if (x > 0 && x <= m && freq[x] == 0) {
            chk.push_back(x);
        }

        freq[x]++;
    }

    ll other = chk.size();

    ll op1 = min(freq[-1] + other, m);
    ll op2 = min(freq[-2] + other, m);

    ll ans = max(op1, op2);

    sort(chk.begin(), chk.end());

    ll cnt = 0;
    ll tot = chk.size();

    for (ll x : chk) {
        ll left = cnt + freq[-1];
        ll right = tot - cnt - 1 + freq[-2];

        ll leftSeat = x - 1;
        ll rightSeat = m - x;

        ll cur = min(left, leftSeat) + min(rightSeat, right);

        ans = max(ans, cur + 1);
        cnt++;
    }

    cout << min(ans, m) << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int tc;
    cin >> tc;

    while (tc--) {
        solve();
    }

    return 0;
}
