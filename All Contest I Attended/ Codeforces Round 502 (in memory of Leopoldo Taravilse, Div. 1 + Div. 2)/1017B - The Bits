void solve() {
    ll n;
    cin >> n;

    string a, b;
    cin >> a >> b;

    vector<ll> ar(4, 0);

    char c1[4] = {'0', '0', '1', '1'};
    char c2[4] = {'0', '1', '0', '1'};

    for(ll i = 0; i < n; i++) {
        for(ll j = 0; j < 4; j++) {
            if(c1[j] == a[i] && c2[j] == b[i]) {
                ar[j]++;
            }
        }
    }

    cout << ar[0] * ar[2] + ar[0] * ar[3] + ar[1] * ar[2];
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
