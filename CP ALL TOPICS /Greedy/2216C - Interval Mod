const int N = 100009;

ll n, k, p, q;
ll a[N], f[N][2], g[N];

void solve() {
    cin >> n >> k >> p >> q;

    for (ll i = 1; i <= n; i++) {
        cin >> a[i];
    }

    for (ll i = 1; i <= n; i++) {
        f[i][0] = (a[i] % p) % q;
        f[i][1] = (a[i] % q) % p;
    }

    g[0] = 0;
    for (ll i = 1; i <= n; i++) {
        g[i] = g[i - 1] + min(f[i][0], f[i][1]);
    }

    f[0][0] = f[0][1] = 0;
    for (ll i = 1; i <= n; i++) {
        f[i][0] += f[i - 1][0];
        f[i][1] += f[i - 1][1];
    }

    ll ans = 1e18;

    for (ll i = k; i <= n; i++) {
        ll cost = min(f[i][0] - f[i - k][0],
                      f[i][1] - f[i - k][1])
                  + g[i - k] + g[n] - g[i];
        ans = min(ans, cost);
    }

    cout << ans;
}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
