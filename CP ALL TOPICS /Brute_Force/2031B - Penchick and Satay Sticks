void solve() {
    int n;
    cin >> n;

    vector<int> ar(n);

    for (int i = 0; i < n; i++) {
        cin >> ar[i];
    }

    bool flg = true;

    for (int i = 0; i < n - 1; i++) {
        if (ar[i] > ar[i + 1] && ar[i] == ar[i + 1] + 1) {
            swap(ar[i], ar[i + 1]);
        }
    }

    for (int i = 0; i < n; i++) {
        if (ar[i] != i + 1) {
            flg = false;
            break;
        }
    }

    if (flg) {
        cout << "YES";
    }
    else {
        cout << "NO";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
