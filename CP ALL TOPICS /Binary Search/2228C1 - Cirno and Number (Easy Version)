ll pw[19];

void solve() {
    ll a, n;
    cin >> a >> n;

    vector<ll> d(n);

    for(ll i = 0; i < n; i++) {
        cin >> d[i];
    }

    if(n == 1) {
        ll x = d[0];

        ll ans = 1e18;

        for(ll i = 0; i < 18; i++) {
            ans = min(ans, abs(x - a));

            x *= 10;

            x += d[0];
        }

        ans = min(ans, abs(x - a));

        cout << ans;

        return;
    }

    string s = to_string(a);

    ll m = s.size();

    ll ans1 = 1e18;
    ll ans2 = 1e18;
    ll ans3 = 1e18;

    ll x = d[0];

    if(x == 0) {
        x = d[1];
    }

    ll y = x * pw[m];

    x = d[0];

    for(ll i = 0; i < m - 1; i++) {
        x = 10 * x + d[0];
    }

    y += x;

    ans1 = abs(y - a);

    if(m > 1) {
        x = d[n - 1];

        for(ll i = 0; i < m - 2; i++) {
            x = 10 * x + d[n - 1];
        }

        ans2 = abs(x - a);
    }

    vector<ll> mn(m + 1), mx(m + 1);

    mn[0] = 0;
    mx[0] = 0;

    mn[1] = d[0];
    mx[1] = d[n - 1];

    for(ll i = 2; i <= m; i++) {
        mn[i] = 10 * mn[i - 1] + d[0];

        mx[i] = 10 * mx[i - 1] + d[n - 1];
    }

    vector<ll> v(m + 1);

    v[m] = a;

    for(ll i = m - 1; i >= 0; i--) {
        v[i] = v[i + 1] % pw[i];
    }

    function<ll(ll)> fun = [&](ll i) {

        if(i == m) {
            return 0LL;
        }

        ll ans = 1e18;

        ll x = s[i] - '0';

        ll it = lower_bound(d.begin(), d.end(), x) - d.begin();

        if(it < n && d[it] == x) {
            ans = min(ans, fun(i + 1));
        }

        ll y = 1e18;
        ll z = 1e18;

        ll it1 = upper_bound(d.begin(), d.end(), x) - d.begin();

        if(it1 < n) {
            y = d[it1] * pw[m - i - 1] + mn[m - i - 1];
        }

        if(it - 1 >= 0) {
            z = d[it - 1] * pw[m - i - 1] + mx[m - i - 1];
        }

        ans = min(ans, min(abs(y - v[m - i]), abs(z - v[m - i])));

        return ans;
    };

    ans3 = fun(0);

    ans1 = min(ans1, min(ans2, ans3));

    cout << ans1;
}






int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    pw[0] = 1;

    for(ll i = 1; i < 19; i++) {
        pw[i] = pw[i - 1] * 10;
    }

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
