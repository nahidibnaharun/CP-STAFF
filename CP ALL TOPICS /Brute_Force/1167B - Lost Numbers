void solve() {
    vector<int> p = {4, 8, 15, 16, 23, 42};
    int ans[4];

    for(int i = 0; i < 4; i++) {
        cout << "? " << i + 1 << " " << i + 2 << endl;
        cout.flush();

        cin >> ans[i];
    }

    do {
        bool good = true;

        for(int i = 0; i < 4; i++) {
            good &= (p[i] * p[i + 1] == ans[i]);
        }

        if(good) break;

    } while(next_permutation(p.begin(), p.end()));

    cout << "!";

    for(int i = 0; i < 6; i++) {
        cout << " " << p[i];
    }

    cout << endl;
    cout.flush();
}





    
