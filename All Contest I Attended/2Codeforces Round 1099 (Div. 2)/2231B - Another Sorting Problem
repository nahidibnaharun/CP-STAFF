void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n);

    for(ll i = 0; i < n; i++) {
        cin >> a[i];
    }

    ll mx = 0;

    for(ll i = 0; i < n - 1; i++) {
        mx = max(mx, a[i] - a[i + 1]);
    }

    for(ll i = 1; i < n; i++) {
        if(a[i] < a[i - 1]) {
            a[i] += mx;
        }
    }

    if(is_sorted(a.begin(), a.end())) {
        cout << "YES";
    }
    else {
        cout << "NO";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
