void solve() {
    int n;
    cin >> n;

    int m = 0;
    int k = 9;
    int maxi = 0;

    while (k--) {
        int sze = (1 << m);
        m++;

        if (sze >= n)
            break;

        int marker = 1;
        int gin = 0;

        vector<int> vec1, vec2;

        for (int i = 1; i <= n; i++) {
            if (marker)
                vec1.push_back(i);
            else
                vec2.push_back(i);

            gin++;

            if (gin == sze) {
                gin = 0;
                marker ^= 1;
            }
        }

        cout << vec2.size() << " " << vec1.size() << " ";

        for (int x : vec2)
            cout << x << " ";

        for (int x : vec1)
            cout << x << " ";

        cout << '\n';
        cout.flush();

        cin >> gin;
        maxi = max(maxi, gin);
    }

    cout << "-1 " << maxi << '\n';
    cout.flush();
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
