void solve(){
      int n, k;
    ll C;
    cin >> n >> C >> k;

    vector<int> a(n + 1);
    for(int i = 1; i <= n; i++){
        cin >> a[i];
    }

    sort(a.begin() + 1, a.end());

    for(int i = 1; i <= n; i++){
        if(a[i] > C) break;

        int o = min(1LL * k, C - a[i]);
        k -= o;
        C += a[i] + o;
    }

    cout << C;
}

int main(){
    ios_base::sync_with_stdio(false);
	cin.tie(NULL);
    
    ll tt; cin >> tt;
    while(tt--){
        solve();
        cout << endl;
    }
    
    
    return 0;   
}
