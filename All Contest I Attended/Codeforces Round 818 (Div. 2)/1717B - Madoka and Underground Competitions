void solve() {
    ll n, k, r, c;
    cin >> n >> k >> r >> c;

    vector<string> grid(n, string(n, '.'));

    ll rem = (r + c) % k;

    for (ll i = 1; i <= n; i++) {
        for (ll j = 1; j <= n; j++) {
            if ((i + j) % k == rem)
                grid[i - 1][j - 1] = 'X';
        }
    }

    for (ll i = 0; i < n; i++)
        cout << grid[i] << '\n';
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
