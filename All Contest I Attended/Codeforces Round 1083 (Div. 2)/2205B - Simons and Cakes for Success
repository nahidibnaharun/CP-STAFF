vector<int> pr;
bool vis[N];

void init(int n = 31623)
{
    for (int i = 2; i <= n; i++)
    {
        if (!vis[i])
        {
            pr.push_back(i);
        }

        for (auto j : pr)
        {
            if (i * j > n)
            {
                break;
            }

            vis[i * j] = true;

            if (i % j == 0)
            {
                break;
            }
        }
    }
}

void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        int ans = 1;

        for (auto i : pr)
        {
            if (1LL * i * i > n)
            {
                break;
            }

            if (n % i == 0)
            {
                ans *= i;

                while (n % i == 0)
                {
                    n /= i;
                }
            }
        }

        ans *= n;

        cout << ans << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    init();
    solve();

    return 0;
}
