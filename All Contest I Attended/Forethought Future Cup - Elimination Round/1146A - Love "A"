void solve() {
    string s;
    cin >> s;

    int l = s.size();
    int c = 0;

    for (char ch : s) {
        if (ch == 'a') c++;
    }

    int x = l - c;

    if (c > x)
        cout << l;
    else
        cout << c + (c - 1);
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;
    // cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
