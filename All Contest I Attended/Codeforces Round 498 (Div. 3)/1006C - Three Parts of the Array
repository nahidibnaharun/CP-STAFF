void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n);

    for(ll i = 0; i < n; i++) {
        cin >> a[i];
    }

    set<ll> sum;

    ll l = 0;

    for(ll i = 0; i < n; i++) {
        l += a[i];
        sum.insert(l);
    }

    ll ans = 0;
    ll r = 0;

    for(ll i = n - 1; i >= 0; i--) {
        sum.erase(l);

        l -= a[i];
        r += a[i];

        if(sum.count(r)) {
            ans = max(ans, r);
        }
    }

    cout << ans;
}






int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while(t--){
        solve();
        cout << endl;
    }

    return 0;
}
