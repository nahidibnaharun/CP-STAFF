void solve() {
    ll n;
    cin >> n;
    
    for(ll i = 1; i <= n; i++) {
        cin >> a[i];
    }
    
    ll preLen = 1;
    while(preLen < n && a[preLen] <= a[preLen + 1]) {
        preLen++;
    }
    
    ll sufLen = 1;
    while(sufLen < n && a[n - sufLen] >= a[n - sufLen + 1]) {
        sufLen++;
    }
    
    if(preLen + sufLen >= n) {
        cout << "YES" << endl;
    } else {
        cout << "NO" << endl;
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while(t--) {
        solve();
    }

    return 0;
}
