void solve() {
    int n;
    cin >> n;

    vector<ll> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }

    sort(a.begin(), a.end());

    ll mn = LLONG_MAX;

    for (int i = 0; i < n - 2; i++) {
        ll sum = 0;
        for (int j = i; j < i + 2; j++) {
            sum += abs(a[j] - a[j + 1]);
        }
        mn = min(mn, sum);
    }

    cout << mn;
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
