void solve() {
    ll n, m, q;
    cin >> n >> m >> q;

    vector<ll> a(n), b(m);

    for(int i = 0; i < n; i++) {
        cin >> a[i];
    }

    for(int i = 0; i < m; i++) {
        cin >> b[i];
    }

    vector<ll> pos(n + 1);

    for(int i = 0; i < n; i++) {
        pos[a[i]] = i;
    }

    map<ll, bool> vis;
    ll cnt = 0;

    for(int i = 0; i < m; i++) {
        ll idx = pos[b[i]];

        if(vis[b[i]]) {
            continue;
        }

        if(cnt == idx) {
            cnt++;
            vis[b[i]] = true;
        }
        else {
            cout << "TIDAK";
            return;
        }
    }

    cout << "YA";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
