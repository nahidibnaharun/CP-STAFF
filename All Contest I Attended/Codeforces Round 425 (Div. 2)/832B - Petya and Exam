bool good[26];

bool match(string pattern, string s) {
    if (pattern.size() != s.size()) {
        return false;
    }

    for (int i = 0; i < s.size(); i++) {
        if (pattern[i] != '?') {
            if (pattern[i] != s[i]) {
                return false;
            }
        } else {
            if (!good[s[i] - 'a']) {
                return false;
            }
        }
    }

    return true;
}

void solve() {
    string goods, pattern;
    int n;
    cin >> goods >> pattern >> n;

    for (char c : goods) {
        good[c - 'a'] = true;
    }

    int pos = pattern.find('*');

    while (n--) {
        string s;
        cin >> s;

        if (s.size() < pattern.size() - 1) {
            cout << "NO\n";
        } else if (pos == string::npos) {
            cout << (match(pattern, s) ? "YES" : "NO") << '\n';
        } else {
            bool ok = true;

            ok &= match(pattern.substr(0, pos), s.substr(0, pos));

            reverse(pattern.begin(), pattern.end());
            reverse(s.begin(), s.end());

            pos = pattern.size() - pos - 1;

            ok &= match(pattern.substr(0, pos), s.substr(0, pos));

            reverse(pattern.begin(), pattern.end());
            reverse(s.begin(), s.end());

            pos = pattern.size() - pos - 1;

            for (int i = pos; i < s.size() - (pattern.size() - pos - 1); i++) {
                ok &= !good[s[i] - 'a'];
            }

            cout << (ok ? "YES" : "NO") << '\n';
        }
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
