void solve() {
    ll n, s;
    cin >> n >> s;

    vector<ll> x(n + 1), y(n + 1);
    vector<vector<ll>> dp(n + 1, vector<ll>(2, 0));

    for (ll i = 1; i <= n; i++) {
        ll a;
        cin >> a;

        if (i == 1 || i == n) {
            x[i] = y[i] = a;
        }
        else if (a <= s) {
            x[i] = 0;
            y[i] = a;
        }
        else {
            x[i] = s;
            y[i] = a - s;
        }
    }

    dp[1][0] = dp[1][1] = 0;

    for (ll i = 2; i <= n; i++) {
        dp[i][0] = min(
            dp[i - 1][0] + y[i - 1] * x[i],
            dp[i - 1][1] + x[i - 1] * x[i]
        );

        dp[i][1] = min(
            dp[i - 1][0] + y[i - 1] * y[i],
            dp[i - 1][1] + x[i - 1] * y[i]
        );
    }

    cout << dp[n][0];
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << '\n';
    }

    return 0;
}
