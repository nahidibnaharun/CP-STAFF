void solve() {
    int n;
    cin >> n;

    if (n <= 3) {
        for (int i = 1; i <= n; i++) cout << i << " ";
        cout << '\n';
        return;
    }

    if (n == 4) {
        cout << "2 4 1 3\n";
        return;
    }

    int dif = n / 2;
    vector<int> ans;  
    
    for (int i = (n + 2) / 2; i <= n; i++) {
        ans.push_back(i);
        if (i - dif != (n + 2) / 2) ans.push_back(i - dif);
    }

    for (auto x : ans) cout << x << " ";
    cout << '\n';
 
}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        // cout<<endl;
    }

    return 0;
}
