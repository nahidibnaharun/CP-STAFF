void solve()
{
    int n;
    cin >> n;

    vector<int> a(n);

    for (int i = 0; i < n; i++)
    {
        cin >> a[i];
    }

    sort(a.begin(), a.end());

    a.resize(unique(a.begin(), a.end()) - a.begin());

    int pnt = 0, ans = 0;

    for (int i = 0; i < (int)a.size(); i++)
    {
        while (a[i] - a[pnt] >= n)
        {
            pnt++;
        }

        ans = max(ans, i - pnt + 1);
    }

    cout << ans << "\n";
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--)
    {
        solve();
    }

    return 0;
}
