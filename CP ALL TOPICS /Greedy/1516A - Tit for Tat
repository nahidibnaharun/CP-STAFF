void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n, k;
        cin >> n >> k;

        vector<int> a(n);
        for (int i = 0; i < n; i++)
            cin >> a[i];

        for (int i = 0; i < n - 1; i++)
        {
            if (a[i] < k)
            {
                k -= a[i];
                a[n - 1] += a[i];
                a[i] = 0;
            }
            else
            {
                a[i] -= k;
                a[n - 1] += k;
                k = 0;
            }
        }

        for (int i = 0; i < n; i++)
            cout << a[i] << " ";
        cout << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
