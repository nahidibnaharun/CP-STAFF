ll nc3(ll x)
{
    return (x * (x - 1) * (x - 2)) / 6;
}

void solve()
{
    ll n, k;
    cin >> n >> k;

    vector<string> v;
    set<string> st;

    ll ctr = 0;

    for (ll j = 0; j < n; j++)
    {
        string s;
        cin >> s;

        for (auto it : st)
        {
            string temp = it;

            for (ll i = k; i >= 0; i--)
            {
                if (temp[i] != s[i])
                {
                    temp[i] ^= (66 ^ s[i]);
                }
            }

            ctr += st.count(temp);
        }

        st.insert(s);
    }

    cout << ctr / 2 << "\n";
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
