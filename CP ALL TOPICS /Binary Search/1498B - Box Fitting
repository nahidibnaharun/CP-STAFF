array<int, PW> arr;
int n, w;

bool valid(int height)
{
    for (int pw = 0; pw < PW; pw++)
    {
        ll units = 1LL * height * (w / (1 << pw));

        if (units < arr[pw])
            return false;
    }

    return true;
}

void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        cin >> n >> w;

        for (int i = 0; i < PW; i++)
            arr[i] = 0;

        for (int i = 0; i < n; i++)
        {
            int x;
            cin >> x;
            arr[log2(x)]++;
        }

        for (int i = PW - 2; i >= 0; i--)
            arr[i] += 2 * arr[i + 1];

        int l = 1, r = n, ans = -1;

        while (l <= r)
        {
            int mid = (l + r) / 2;

            if (valid(mid))
            {
                ans = mid;
                r = mid - 1;
            }
            else
                l = mid + 1;
        }

        cout << ans << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
