ld c[MAX], p[MAX];

void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        for (int i = 1; i <= n; i++)
        {
            int cv, pv;
            cin >> cv >> pv;

            c[i] = cv;
            p[i] = pv / 100.0;
        }

        ld ans = 0;

        for (int i = n; i >= 1; i--)
        {
            ans = max(ans, ans * (1 - p[i]) + c[i]);
        }

        cout << fixed << setprecision(10) << ans << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
