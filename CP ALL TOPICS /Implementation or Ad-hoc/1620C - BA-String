void solve() {
    ll n, k, x;
    cin >> n >> k >> x;
    x--;

    string s;
    cin >> s;
    reverse(s.begin(), s.end());

    vector<string> res;

    for (ll i = 0; i < n; i++) {
        if (s[i] == 'a') res.push_back("a");
        else {
            ll j = i;
            while (j + 1 < n && s[j + 1] == s[i]) j++;

            ll cur = (j - i + 1) * k + 1;
            res.push_back(string(x % cur, 'b'));
            x /= cur;
            i = j;
        }
    }

    reverse(res.begin(), res.end());

    for (auto &u : res) cout << u;
    cout << endl;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
    }

    return 0;
}
