vector<ll> divisor;
set<ll> st;
void getDivisors(ll n)
{
    for (ll i = 1; i * i <= n; i++)
    {
        if (n % i == 0)
        {
            if (st.find(i) == st.end())
            {
                divisor.push_back(i);
                st.insert(i);
            }
            if (i != (n / i))
            {
                if (st.find(n / i) == st.end())
                {
                    divisor.push_back(n / i);
                    st.insert(n / i);
                }
            }
        }
    }
}
ll range_sum(ll l, ll r)
{
    if (l > r)
        return 0;
    return (l + r) * (r - l + 1) / 2;
}
