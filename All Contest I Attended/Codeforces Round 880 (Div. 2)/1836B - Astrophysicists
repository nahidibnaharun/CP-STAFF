void solve() {
    ll n, k, g;
    cin >> n >> k >> g;

    ll sl = min(((g - 1) / 2) * n, k * g);
    ll rt = (k * g - sl) % g;

    if (rt > 0) {
        sl -= (g - 1) / 2;
        ll last = ((g - 1) / 2 + rt) % g;

        if (last * 2 < g) {
            sl += last;
        } else {
            sl -= (g - last);
        }
    }

    cout << sl;
}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
