void solve() {
    int n;
    cin >> n;

    vector<int> a(n);

    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }

    ll sum = accumulate(a.begin(), a.end(), 0LL);
    ll cur = 0;
    ll ans = 1;

    for (int i = 0; i < n - 1; i++) {
        cur += a[i];
        sum -= a[i];

        ans = max(ans, __gcd(cur, sum));
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
