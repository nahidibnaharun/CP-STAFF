int cnt[MAX];
vector<int> a;
int n;

bool check(int x) {
    for (int i = 1; i <= n; i++) {
        cnt[i] = 0;
    }

    for (int i = 0; i < n; i++) {
        cnt[a[i]]++;
    }

    set<pair<int, int>, greater<pair<int, int>>> st;

    for (int i = 1; i <= n; i++) {
        if (cnt[i] > 0) {
            st.insert({cnt[i], i});
        }
    }

    vector<int> b;

    for (int i = 0; i < n; i++) {
        if (i >= x && cnt[b[i - x]]) {
            st.insert({cnt[b[i - x]], b[i - x]});
        }

        if (st.empty()) {
            return false;
        }

        b.push_back(st.begin()->second);
        st.erase(st.begin());

        cnt[b.back()]--;
    }

    return true;
}

void solve() {
    cin >> n;

    a.resize(n);

    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }

    int l = 0, r = n;

    while (r - l > 1) {
        int mid = (l + r) / 2;

        if (check(mid)) {
            l = mid;
        }
        else {
            r = mid;
        }
    }

    cout << l - 1 << '\n';
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
