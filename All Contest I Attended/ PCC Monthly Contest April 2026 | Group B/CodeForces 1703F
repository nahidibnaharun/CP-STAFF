void solve(){
 int n; cin >> n;
    vector<int>a(n);
    for(auto &x:a)cin >> x;
    ll res=0;
    vector<int>v;
    for(int i=0 ;i<n;i++){
        if(a[i]>=i+1)continue;
       
		res += (ll)(lower_bound(v.begin(), v.end(), a[i]) - v.begin());
		v.push_back(i+1);
    }
    cout<<res;
}

    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
