void solve() {
    int n;
    cin >> n;

    vector<int> ar(n);
    for (int i = 0; i < n; i++) cin >> ar[i];

    if (n % 2 != 0) {
        cout << "NO";
        return;
    }

    sort(ar.begin(), ar.end());

    int md = n / 2;
    bool chk = false;

    for (int i = 0, j = md; i < md - 1; i++, j++) {
        if (ar[i] == ar[j] || ar[i + 1] == ar[j]) {
            chk = true;
            break;
        }
    }

    if (chk) {
        cout << "NO";
    }
    else if (ar[md - 1] != ar[n - 1] && ar[0] != ar[n - 1]) {
        cout << "YES\n";
        for (int i = 0, j = md; j < n; i++, j++) {
            cout << ar[i] << " " << ar[j] << " ";
        }
    }
    else {
        cout << "NO";
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
