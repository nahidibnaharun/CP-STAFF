int a[MAX];

void solve() {
    int n;
    cin >> n;

    bool one = false;

    for (int i = 1; i <= n; i++) {
        cin >> a[i];

        if (a[i] == 1) {
            one = true;
        }
    }

    if (one) {
        cout << "Yes\n";
        return;
    }

    sort(a + 1, a + n + 1);

    vector<int> b;

    for (int i = 2; i <= n; i++) {
        if (a[i] % a[1] != 0) {
            b.push_back(a[i]);
        }
    }

    if (b.empty()) {
        cout << "Yes\n";
        return;
    }

    sort(b.begin(), b.end());

    bool ok = true;

    for (int i = 1; i < (int)b.size(); i++) {
        if (b[i] % b[0] != 0) {
            ok = false;
            break;
        }
    }

    cout << (ok ? "Yes\n" : "No\n");
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
