void solve() {
  
    ll n, m;
    cin >> n >> m;

    vector<ll> a(n + 2, 0);

    for (ll i = 1; i <= n; ++i) {
        cin >> a[i];
    }

    ll ans = 0;

    for (ll i = 1; i <= n; ++i) {
        ans += (a[i] != a[i + 1]) * (n - i) * i;
    }

    while (m--) {
        ll i, x;
        cin >> i >> x;

        ans -= (a[i] != a[i - 1]) * (n - i + 1) * (i - 1);
        ans -= (a[i + 1] != a[i]) * (n - i) * i;

        a[i] = x;

        ans += (a[i] != a[i - 1]) * (n - i + 1) * (i - 1);
        ans += (a[i + 1] != a[i]) * (n - i) * i;

        cout << ans + n * (n + 1) / 2 << '\n';
    }
    
}



    
