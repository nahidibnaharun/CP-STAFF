void solve() {
  
    
    ll n;
    cin >> n;

    ll a[n];
    for (ll i = 0; i < n; i++) cin >> a[i];

    if (n <= 2) {
        cout << 0;
        return;
    }

    ll ans = n;

    for (ll l = 0; l < n; l++) {
        for (ll r = l + 1; r < n; r++) {

            ll cnt = 0;

            for (ll i = 0; i < n; i++) {
               
                if ((a[i] - a[l]) * (r - l) != (a[r] - a[l]) * (i - l)) {
                    cnt++;
                }
            }

            ans = min(ans, cnt);
        }
    }

    cout << ans;
}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
