vector<ll> g[MAX];
ll depth[MAX], dp[MAX];
ll ans[MAX];

void dfs(ll v, ll p = -1) {
    ans[v] = 0;
    dp[v] = depth[v];

    ll mx1 = depth[v], mx2 = depth[v];

    for (ll u : g[v]) {
        if (u == p)
            continue;

        depth[u] = depth[v] + 1;
        dfs(u, v);

        dp[v] = max(dp[v], dp[u]);
        ans[v] += ans[u];

        if (dp[u] >= mx1) {
            mx2 = mx1;
            mx1 = dp[u];
        }
        else if (dp[u] >= mx2) {
            mx2 = dp[u];
        }
    }

    ans[v] += mx2 - depth[v] + 1;
}

void solve() {
    ll n;
    cin >> n;

    for (ll i = 0; i < n; i++) {
        g[i].clear();
        depth[i] = 0;
        dp[i] = 0;
        ans[i] = 0;
    }

    for (ll i = 1; i < n; i++) {
        ll p;
        cin >> p;
        g[p - 1].push_back(i);
    }

    dfs(0);

    cout << ans[0];
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
