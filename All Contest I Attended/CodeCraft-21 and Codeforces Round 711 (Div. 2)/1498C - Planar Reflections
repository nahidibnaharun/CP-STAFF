int n, k;
int dp[N][K][2];

int go(int curr, int step, int dir)
{
    if (step == 1)
        return 1;

    if (dp[curr][step][dir] != -1)
        return dp[curr][step][dir];

    int ans = 2;

    if (dir == 1)
    {
        if (curr < n)
            ans = (ans + go(curr + 1, step, dir) - 1) % MOD;

        if (curr > 1)
            ans = (ans + go(curr - 1, step - 1, 1 - dir) - 1) % MOD;
    }
    else
    {
        if (curr > 1)
            ans = (ans + go(curr - 1, step, dir) - 1) % MOD;

        if (curr < n)
            ans = (ans + go(curr + 1, step - 1, 1 - dir) - 1) % MOD;
    }

    return dp[curr][step][dir] = ans;
}

void solve()
{
    int t;
    cin >> t;

    while (t--)
    {
        cin >> n >> k;

        memset(dp, -1, sizeof(dp));

        cout << go(1, k, 1) << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
