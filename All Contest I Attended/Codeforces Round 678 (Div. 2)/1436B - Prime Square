#include <bits/stdc++.h>
using namespace std;

using ll = long long;

void solve()
{
    ll n;
    cin >> n;

    for (ll i = 1; i <= n / 2; i++)
    {
        for (ll j = 1; j <= n / 2; j++)
        {
            if (i == j)
                cout << "1 1 ";
            else
                cout << "0 0 ";
        }

        if (n % 2 && i == 1)
            cout << "1 ";
        else if (n % 2)
            cout << "0 ";

        cout << "\n";

        for (ll j = 1; j <= n / 2; j++)
        {
            if (i == j)
                cout << "1 1 ";
            else
                cout << "0 0 ";
        }

        if (n % 2 && i == 1)
            cout << "1 ";
        else if (n % 2)
            cout << "0 ";

        cout << "\n";
    }

    if (n % 2)
    {
        cout << "1 0 ";
        for (ll i = 1; i <= n / 2 - 1; i++)
            cout << "0 0 ";
        cout << "1\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;
    while (t--)
        solve();

    return 0;
}
