void solve() {
    ll t;
    cin >> t;

    char s[42];

    while (t--) {
        cin >> s;

        ll k = strlen(s + 4);
        ll year = atoi(s + 4);
        ll F = 0;
        ll tenPow = 10;

        for (ll i = 1; i < k; i++) {
            F += tenPow;
            tenPow *= 10;
        }

        while (year < 1989 + F) year += tenPow;

        cout << year << '\n';
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
