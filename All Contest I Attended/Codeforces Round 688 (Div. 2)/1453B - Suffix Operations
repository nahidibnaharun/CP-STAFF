void solve() {
     ll n;
    cin >> n;

    vector<ll> a(n + 2);

    for (ll i = 1; i <= n; i++) cin >> a[i];

    ll ans = 0;

    for (ll i = 2; i <= n; i++) {
        ans += abs(a[i] - a[i - 1]);
    }

    ll mx = max(abs(a[1] - a[2]), abs(a[n] - a[n - 1]));

    for (ll i = 2; i < n; i++) {
        mx = max(mx,
                 abs(a[i] - a[i - 1]) +
                 abs(a[i + 1] - a[i]) -
                 abs(a[i + 1] - a[i - 1]));
    }

    cout << ans - mx;
 
}



    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while (t--)
    {
        solve();
        cout<<endl;
    }

    return 0;
}
