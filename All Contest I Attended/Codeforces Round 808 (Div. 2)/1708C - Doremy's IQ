int n, q;
vector<int> a, choose;

bool check(int mid) {
    fill(choose.begin(), choose.end(), 0);

    int iq = q;

    for(int i = 1; i < mid; i++) {
        if(a[i] <= iq) {
            choose[i] = 1;
        }
    }

    for(int i = mid; i <= n; i++) {
        choose[i] = 1;

        if(iq == 0) {
            return false;
        }

        if(a[i] > iq) {
            iq--;
        }
    }

    return iq >= 0;
}

void solve() {
    cin >> n >> q;

    a.assign(n + 1, 0);
    choose.assign(n + 1, 0);

    for(int i = 1; i <= n; i++) {
        cin >> a[i];
    }

    int l = 1, r = n;

    while(l <= r) {
        int mid = (l + r) / 2;

        if(check(mid)) {
            r = mid - 1;
        }
        else {
            l = mid + 1;
        }
    }

    check(r + 1);

    for(int i = 1; i <= n; i++) {
        cout << choose[i];
    }

    cout << '\n';
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
    }

    return 0;
}
