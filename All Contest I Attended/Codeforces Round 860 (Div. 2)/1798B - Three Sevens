vector<ll> last(MAX + 777, 0);

void solve() {
    ll m;
    cin >> m;

    vector<vector<ll>> a_(m);

    for (ll day = 0; day < m; day++) {
        ll n;
        cin >> n;

        vector<ll> a(n);

        for (ll i = 0; i < n; i++) {
            cin >> a[i];
            last[a[i]] = day;
        }

        a_[day] = a;
    }

    vector<ll> ans(m, -1);

    for (ll day = 0; day < m; day++) {
        for (auto x : a_[day]) {
            if (last[x] == day) {
                ans[day] = x;
            }
        }

        if (ans[day] == -1) {
            cout << -1;
            return;
        }
    }

    for (ll i = 0; i < m; i++) {
        if (i) cout << " ";
        cout << ans[i];
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
