void solve() {
    
    ll n;
    cin >> n;

    vector<ll> s(n);

    for(ll i = 0; i < n; ++i){
        cin >> s[i];
    }

    ll mex = -1;

    for(ll i = 0; i < n; ++i){

        if(i == 0 && s[i] != 0){
            mex = 0;
            break;
        }

        if(i > 0 && s[i] != s[i - 1] + 1){
            mex = s[i - 1] + 1;
            break;
        }
    }

    if(mex == -1){
        mex = s[n - 1] + 1;
    }

    cout << mex << endl;

    ll y;
    cin >> y;

    while(y != -1){

        cout << y << endl;
        cin >> y;
    }
}






    
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    ll t;
    cin >> t;

    while(t--){
        solve();
    }

    return 0;
}
