ll lcm(ll a, ll b) {
    return a / __gcd(a, b) * b;
}

void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n), b(n);

    for (ll i = 0; i < n; i++) {
        cin >> a[i] >> b[i];
    }

    ll g = 0;
    ll l = 1;
    ll ans = 1;

    for (ll i = 0; i < n; i++) {
        g = __gcd(g, a[i] * b[i]);
        l = lcm(l, b[i]);

        if (g % l != 0) {
            ans++;
            g = a[i] * b[i];
            l = b[i];
        }
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
