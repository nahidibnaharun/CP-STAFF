void solve() {
    ll n;
    cin >> n;

    vector<ll> a(n), b(n);

    for (ll i = 0; i < n; i++) {
        cin >> a[i];
    }

    for (ll i = 0; i < n; i++) {
        cin >> b[i];
    }

    ll l = -1, r = -1;

    for (ll i = 0; i < n; i++) {
        if (a[i] != b[i]) {
            r = i;
            if (l == -1) {
                l = i;
            }
        }
    }

    while (l > 0 && b[l - 1] <= b[l]) {
        l--;
    }

    while (r < n - 1 && b[r + 1] >= b[r]) {
        r++;
    }

    cout << l + 1 << " " << r + 1;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
