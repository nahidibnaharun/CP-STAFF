void solve()
{
    int n;
    cin >> n;

    const int A = 1e9 + 1;

    int minL = A, costL = A;
    int maxR = 0, costR = A;
    int maxLen = 0, costLen = A;

    for (int i = 0; i < n; i++)
    {
        int l, r, c;
        cin >> l >> r >> c;

        if (l < minL)
        {
            minL = l;
            costL = A;
        }

        if (l == minL)
        {
            costL = min(costL, c);
        }

        if (r > maxR)
        {
            maxR = r;
            costR = A;
        }

        if (r == maxR)
        {
            costR = min(costR, c);
        }

        int len = r - l + 1;

        if (len > maxLen)
        {
            maxLen = len;
            costLen = A;
        }

        if (len == maxLen)
        {
            costLen = min(costLen, c);
        }

        int ans = costL + costR;

        if (maxLen == maxR - minL + 1)
        {
            ans = min(ans, costLen);
        }

        cout << ans << "\n";
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--)
    {
        solve();
    }

    return 0;
}
