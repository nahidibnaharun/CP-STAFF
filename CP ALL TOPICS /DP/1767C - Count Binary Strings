const ll N = 143;

ll n;
ll a[N][N];
ll dp[N][N];

ll add(ll x, ll y) {
    x += y;

    while (x >= MOD) {
        x -= MOD;
    }

    while (x < 0) {
        x += MOD;
    }

    return x;
}

ll mul(ll x, ll y) {
    return (x * y) % MOD;
}

bool check(ll cnt, ll last) {
    for (ll i = 0; i < cnt; i++) {
        if (a[i][cnt - 1] == 0) {
            continue;
        }

        if (a[i][cnt - 1] == 1 && last > i) {
            return false;
        }

        if (a[i][cnt - 1] == 2 && last <= i) {
            return false;
        }
    }

    return true;
}

void solve() {
    cin >> n;

    for (ll i = 0; i < n; i++) {
        for (ll j = i; j < n; j++) {
            cin >> a[i][j];
        }
    }

    if (a[0][0] != 2) {
        dp[1][0] = 2;
    }

    for (ll i = 1; i < n; i++) {
        for (ll j = 0; j < i; j++) {
            for (ll k : {j, i}) {
                if (check(i + 1, k)) {
                    dp[i + 1][k] = add(dp[i + 1][k], dp[i][j]);
                }
            }
        }
    }

    ll ans = 0;

    for (ll i = 0; i < n; i++) {
        ans = add(ans, dp[n][i]);
    }

    cout << ans;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t = 1;

    while (t--) {
        solve();
        cout << endl;
    }

    return 0;
}
