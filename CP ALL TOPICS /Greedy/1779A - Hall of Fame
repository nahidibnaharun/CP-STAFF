void solve()
{
    int t = 1;
    cin >> t;

    while (t--)
    {
        int n;
        cin >> n;

        string s;
        cin >> s;

        int ans = -1;

        for (int i = 0; i < n - 1; i++)
        {
            if (s[i] == 'R' && s[i + 1] == 'L')
            {
                ans = 0;
                break;
            }

            if (s[i] == 'L' && s[i + 1] == 'R')
            {
                ans = i + 1;
                break;
            }
        }

        cout << ans << '\n';
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
