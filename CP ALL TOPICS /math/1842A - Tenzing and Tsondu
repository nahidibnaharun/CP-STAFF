int a[55], b[55];

void solve() {
    int n, m;
    cin >> n >> m;

    ll sumA = 0, sumB = 0;

    for (int i = 1; i <= n; i++) {
        cin >> a[i];
        sumA += a[i];
    }

    for (int i = 1; i <= m; i++) {
        cin >> b[i];
        sumB += b[i];
    }

    if (sumA > sumB) {
        cout << "Tsondu\n";
    }
    else if (sumA < sumB) {
        cout << "Tenzing\n";
    }
    else {
        cout << "Draw\n";
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
