void solve() {
    int n;
    ll k;

    cin >> n >> k;

    vector<int> a(n);

    for(int i = 0; i < n; i++) {
        cin >> a[i];
    }

    if(k > 1) {
        k = 2 + k % 2;
    }

    while(k--) {
        int mx = -INF;

        for(int i = 0; i < n; i++) {
            mx = max(mx, a[i]);
        }

        for(int i = 0; i < n; i++) {
            a[i] = mx - a[i];
        }
    }

    for(int i = 0; i < n; i++) {
        cout << a[i];

        if(i + 1 != n) {
            cout << ' ';
        }
    }
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    ll t;
    cin >> t;

    while(t--) {
        solve();
        cout << endl;
    }

    return 0;
}
